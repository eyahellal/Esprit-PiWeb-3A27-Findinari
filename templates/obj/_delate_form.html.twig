<form method="post" action="{{ path('objectif_delete', {'id': objectif.id}) }}" onsubmit="return confirm('Supprimer cet objectif ? Toutes les contributions seront remboursées.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ objectif.id) }}">
    <button class="btn btn-danger">🗑 Supprimer</button>
</form>
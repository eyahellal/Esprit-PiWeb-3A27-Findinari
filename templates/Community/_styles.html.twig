<style>
:root{
  --community-primary:#635bff;
  --community-primary-strong:#4f46e5;
  --community-primary-soft:rgba(99,91,255,.10);
  --community-text:#111827;
  --community-muted:#6b7280;
  --community-border:rgba(17,24,39,.08);
  --community-surface:#ffffff;
  --community-surface-soft:#f8f9fc;
  --community-shadow:0 18px 42px rgba(15,23,42,.07);
}
.community-shell{max-width:1160px;margin:0 auto}
.community-toolbar,.community-post,.community-panel{border-radius:30px;overflow:visible;background:var(--community-surface);border:1px solid var(--community-border);box-shadow:var(--community-shadow)}
.community-toolbar .card-body,.community-post .card-body,.community-panel .card-body{padding:2rem!important}
.community-badge{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem .95rem;border-radius:999px;background:var(--community-primary-soft);color:var(--community-primary);font-weight:700;font-size:.84rem}
.community-avatar,.community-mini-avatar{width:56px;height:56px;border-radius:20px;background:#eef0ff;color:var(--community-primary);display:flex;align-items:center;justify-content:center;font-weight:800;flex-shrink:0;font-size:1.1rem}
.community-mini-avatar{width:46px;height:46px;border-radius:17px;font-size:1rem}
.community-avatar.gradient{background:linear-gradient(135deg,#635bff 0%,#7b76ff 100%);color:#fff}
.community-dot{width:4px;height:4px;border-radius:999px;background:#c5cad7;display:inline-block}
.community-search-input,
.community-editor,
.community-comment-field,
.community-edit-field{width:100%;border:none!important;background:transparent!important;color:var(--community-text)!important;box-shadow:none!important;resize:vertical;padding:0!important;line-height:1.8;transition:all .2s ease}
.community-search-input:focus,
.community-editor:focus,
.community-comment-field:focus,
.community-edit-field:focus{outline:none;box-shadow:none!important}
.community-search-shell,.community-editor-shell,.community-comment-shell{background:#fff;border:1px solid rgba(17,24,39,.10);border-radius:24px;padding:1rem 1.2rem;transition:border-color .2s ease, box-shadow .2s ease, transform .2s ease}
.community-search-shell:focus-within,.community-editor-shell:focus-within,.community-comment-shell:focus-within{border-color:rgba(99,91,255,.38);box-shadow:0 0 0 4px rgba(99,91,255,.10);transform:translateY(-1px)}
.community-search-shell{min-height:64px;display:flex;align-items:center}
.community-editor-shell{min-height:190px;padding:1.2rem 1.3rem}
.community-comment-shell{min-height:136px;padding:1rem 1.15rem}
.community-editor{min-height:160px;font-size:1.06rem}
.community-comment-field{min-height:108px;font-size:1rem}
.community-edit-field{min-height:220px;font-size:1.04rem}
.community-composer-head{display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;margin-bottom:1rem}
.community-upload-btn,.community-search-btn,.community-reset-btn,.community-action-btn{border-radius:999px!important;padding:.86rem 1.3rem!important;font-weight:700;font-size:.95rem}
.community-upload-btn[disabled]{opacity:1;background:#f9fafb;border-color:rgba(17,24,39,.10);color:#6b7280}
.community-post-content{font-size:1.05rem;line-height:1.95;color:var(--community-text);word-break:break-word}
.community-actions{border-top:1px solid rgba(17,24,39,.06);padding-top:1rem}
.community-comments-preview{border-top:1px solid rgba(17,24,39,.06);padding-top:1.1rem}
.community-comment-preview{background:var(--community-surface-soft);border:1px solid rgba(17,24,39,.05);padding:1.1rem 1.15rem;border-radius:22px;min-height:108px}
.community-comment-preview a{word-break:break-word}
.community-meta-link{color:inherit;text-decoration:none}
.community-meta-link:hover strong,.community-post-link:hover{color:var(--community-primary)}
.community-post-link{text-decoration:none;color:inherit;display:block}
.community-menu{position:relative;z-index:25}
.community-menu summary{list-style:none;cursor:pointer;border:none;background:#f4f5fb;color:#6b7280;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;line-height:1;transition:all .2s ease}
.community-menu summary::-webkit-details-marker{display:none}
.community-menu summary:hover{background:#eceeff;color:var(--community-primary)}
.community-menu[open] summary{background:#eceeff;color:var(--community-primary)}
.community-menu-box{position:absolute;right:0;top:48px;min-width:180px;background:#fff;border:1px solid rgba(17,24,39,.08);border-radius:18px;padding:.45rem;box-shadow:0 18px 44px rgba(15,23,42,.16);z-index:30}
.community-menu-link,.community-menu-button{display:flex;align-items:center;width:100%;background:transparent;border:none;border-radius:12px;padding:.8rem .95rem;color:#374151;text-align:left;text-decoration:none;font-size:.95rem}
.community-menu-link:hover,.community-menu-button:hover{background:#f7f8ff;color:var(--community-primary)}
.community-menu-button.text-danger{color:#dc2626}
.community-menu-button.text-danger:hover{background:#fff1f2;color:#dc2626}
.community-panel-title{font-size:1.55rem;font-weight:700;margin-bottom:1rem}
.community-inline-row{display:flex;flex-direction:column;gap:.9rem}
.community-empty{padding:3rem 1.5rem;text-align:center;color:var(--community-muted)}
.community-caption{font-size:.94rem;color:var(--community-muted)}
.community-comment-actions{display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-top:.85rem}
@media (max-width:991.98px){.community-composer-head{flex-direction:column}.community-menu-box{right:auto;left:0}.community-shell{max-width:100%}}
@media (max-width:767.98px){.community-toolbar .card-body,.community-post .card-body,.community-panel .card-body{padding:1.25rem!important}.community-avatar{width:48px;height:48px;border-radius:18px}.community-mini-avatar{width:42px;height:42px;border-radius:15px}.community-editor-shell{min-height:170px}.community-comment-shell{min-height:122px}}
</style>
<script>
document.addEventListener('click', function (event) {
  document.querySelectorAll('.community-menu[open]').forEach(function(menu) {
    if (!menu.contains(event.target)) {
      menu.removeAttribute('open');
    }
  });
});
</script>

{% extends 'base.html.twig' %}

{% block title %}Modifier le commentaire{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="bg-white rounded shadow-sm p-4">
                    <h2 class="mb-3">Modifier le commentaire</h2>

                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_widget(form.contenu, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                            {{ form_errors(form.contenu) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                            <a href="{{ path('community_show', {id: commentaire.post.idPost}) }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
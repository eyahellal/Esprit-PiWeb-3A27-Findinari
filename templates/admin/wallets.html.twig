<!DOCTYPE html>
<html>
<head>
    <title>Manage Wallets</title>
    <style>
        body{
            margin:0;
            font-family:Arial,sans-serif;
            background:#f5f5f9;
            color:#233242;
        }
        .layout{
            display:flex;
            min-height:100vh;
        }
        .sidebar{
            width:260px;
            background:#fff;
            border-right:1px solid #e5e7eb;
            padding:25px 18px;
        }
        .brand{
            font-size:34px;
            font-weight:800;
            color:#696cff;
            margin-bottom:25px;
        }
        .side-link{
            display:block;
            text-decoration:none;
            color:#455a64;
            padding:12px 14px;
            border-radius:12px;
            margin-bottom:8px;
            font-weight:700;
        }
        .side-link.active{
            background:#eef0ff;
            color:#696cff;
        }
        .content{
            flex:1;
            padding:25px;
        }
        .topbar{
            background:#fff;
            border-radius:16px;
            padding:18px 22px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:22px;
            box-shadow:0 4px 18px rgba(0,0,0,.05);
        }
        .section{
            background:#fff;
            border-radius:18px;
            padding:22px;
            box-shadow:0 4px 18px rgba(0,0,0,.05);
            margin-bottom:22px;
        }
        table{
            width:100%;
            border-collapse:collapse;
        }
        th, td{
            text-align:left;
            padding:14px 10px;
            border-bottom:1px solid #eef2f7;
            vertical-align:top;
        }
        th{
            color:#6b7280;
            font-size:14px;
        }
        .btn{
            border:none;
            border-radius:10px;
            padding:10px 14px;
            cursor:pointer;
            font-weight:700;
        }
        .btn-danger{ background:#ff3e1d; color:#fff; }
        .flash{
            padding:14px;
            border-radius:12px;
            margin-bottom:18px;
            font-weight:700;
        }
        .success{ background:#e8fff1; color:#166534; }
        .danger{ background:#ffecec; color:#991b1b; }
    </style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <div class="brand">Sneat</div>
        <a class="side-link" href="{{ path('app_admin_dashboard') }}">Dashboard</a>
        <a class="side-link active" href="{{ path('app_admin_wallets') }}">Manage Wallets</a>
        <a class="side-link" href="{{ path('app_home') }}">Back to site</a>
        <a class="side-link" href="{{ path('app_logout') }}">Logout</a>
    </aside>

    <main class="content">
        <div class="topbar">
            <div style="font-size:24px; font-weight:800;">Wallet Management</div>
            <div>Welcome {{ app.user.prenom }} {{ app.user.nom }}</div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="flash success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="flash danger">{{ message }}</div>
        {% endfor %}

        <div class="section">
            <h2 style="margin-top:0;">All Wallets</h2>
            <table>
                <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Country</th>
                    <th>Balance</th>
                    <th>Currency</th>
                    <th>Delete</th>
                </tr>
                </thead>
                <tbody>
                {% for wallet in wallets %}
                    <tr>
                        <td>{{ wallet.id }}</td>
                        <td>{{ wallet.utilisateur ? wallet.utilisateur.gmail : '' }}</td>
                        <td>{{ wallet.pays }}</td>
                        <td>{{ wallet.solde }}</td>
                        <td>{{ wallet.devise }}</td>
                        <td>
                            <form method="post" action="{{ path('app_admin_wallet_delete', {id: wallet.id}) }}" onsubmit="return confirm('Delete this wallet?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_wallet_admin_' ~ wallet.id) }}">
                                <button class="btn btn-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">No wallets found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>
</body>
</html>
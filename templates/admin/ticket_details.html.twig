                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    const chat = document.getElementById('chatContainer');
    chat.scrollTop = chat.scrollHeight;

    function toggleMenu(id) {
        event.stopPropagation();
        document.querySelectorAll('.dropdown-menu').forEach(m => {
            if(m.id !== 'menu-'+id) m.style.display = 'none';
        });
        const menu = document.getElementById('menu-' + id);
        menu.style.display = (menu.style.display === 'flex') ? 'none' : 'flex';
    }

    document.addEventListener('click', () => {
        document.querySelectorAll('.dropdown-menu').forEach(m => m.style.display = 'none');
    });

    // Handle file selection display
    const fileInput = document.getElementById('{{ form.attachment.vars.id }}');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    
    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files && this.files.length > 0) {
                fileNameDisplay.textContent = 'Selected: ' + this.files[0].name;
                fileNameDisplay.style.display = 'block';
            } else {
                fileNameDisplay.style.display = 'none';
            }
        });
    }

    function editMsg(id, content) {
        document.getElementById('bubble-' + id).style.display = 'none';
        const form = document.getElementById('edit-form-' + id);
        form.style.display = 'block';
        form.querySelector('textarea').value = content;
    }

    // Voice Recording Logic
    let mediaRecorder;
    let audioChunks = [];
    let startTime;
    let timerInterval;

    const micBtn = document.getElementById('micBtn');
    const recorderPanel = document.getElementById('recorderPanel');
    const standardSendBtn = document.getElementById('standardSendBtn');
    const stopRecordBtn = document.getElementById('stopRecord');
    const cancelRecordBtn = document.getElementById('cancelRecord');
    const timerDisplay = document.getElementById('recordTimer');

    micBtn.onclick = async () => {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream);
            audioChunks = [];

            mediaRecorder.ondataavailable = event => audioChunks.push(event.data);
            mediaRecorder.onstop = async () => {
                const audioBlob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
                const formData = new FormData();
                formData.append('audio', audioBlob, 'voice_message.webm');

                try {
                    const response = await fetch("{{ path('app_admin_message_voice', {id: ticket.id}) }}", {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: formData
                    });
                    
                    const contentType = response.headers.get("content-type");
                    if (contentType && contentType.indexOf("application/json") !== -1) {
                        const result = await response.json();
                        console.log('Voice upload response:', result);
                        if (result.success) {
                            window.location.reload();
                        } else {
                            alert('Upload failed: ' + (result.error || 'Unknown error'));
                        }
                    } else {
                        // Probably HTML error page from Symfony
                        const text = await response.text();
                        console.error('Server returned non-JSON response:', text);
                        alert('Server error: The server returned an invalid response. Please check your Cloudinary configuration in .env and clear your Symfony cache.');
                    }
                } catch (err) {
                    console.error('Upload process failed:', err);
                    alert('Could not send voice message: ' + err.message);
                    
                    // Reset UI on error
                    recorderPanel.style.display = 'none';
                    micBtn.style.display = 'flex';
                    standardSendBtn.style.display = 'flex';
                }
            };

            mediaRecorder.start();
            micBtn.style.display = 'none';
            standardSendBtn.style.display = 'none';
            recorderPanel.style.display = 'flex';
            
            startTime = Date.now();
            timerInterval = setInterval(() => {
                const seconds = Math.floor((Date.now() - startTime) / 1000);
                const m = Math.floor(seconds / 60).toString().padStart(2, '0');
                const s = (seconds % 60).toString().padStart(2, '0');
                timerDisplay.textContent = `${m}:${s}`;
            }, 1000);

        } catch (err) {
            console.error('Mic access denied:', err);
            alert('Mic access denied. Please enable microphone permissions.');
        }
    };

    stopRecordBtn.onclick = () => {
        mediaRecorder.stop();
        mediaRecorder.stream.getTracks().forEach(t => t.stop());
        clearInterval(timerInterval);
    };

    cancelRecordBtn.onclick = () => {
        mediaRecorder.onstop = null; // Prevent upload
        mediaRecorder.stop();
        mediaRecorder.stream.getTracks().forEach(t => t.stop());
        clearInterval(timerInterval);
        recorderPanel.style.display = 'none';
        micBtn.style.display = 'flex';
        standardSendBtn.style.display = 'flex';
        timerDisplay.textContent = '00:00';
    };

    // Shared Audio Player logic
    let currentAudio = null;
    window.toggleAudio = function(btn, url) {
        if (currentAudio && currentAudio.src === url) {
            if (currentAudio.paused) {
                currentAudio.play();
                btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" style="width:16px; height:16px;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
            } else {
                currentAudio.pause();
                btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" style="width:16px; height:16px;"><path d="M8 5v14l11-7z"/></svg>';
            }
        } else {
            if (currentAudio) currentAudio.pause();
            currentAudio = new Audio(url);
            currentAudio.play();
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" style="width:16px; height:16px;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
            
            currentAudio.onended = () => {
                btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" style="width:16px; height:16px;"><path d="M8 5v14l11-7z"/></svg>';
            };
        }
    };
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const suggestionsBox = document.getElementById('suggestionsBox');
    // Robust textarea selector
    const textarea = document.getElementById('{{ form.contenu.vars.id }}') || document.querySelector('#replyForm .modern-textarea');
    const ticketId = {{ ticket.id }};
    const suggestionsUrl = '{{ path('app_ticket_message_suggestions', {id: ticket.id}) }}';

    console.log('AI System: Initializing for Admin...', { suggestionsBox: !!suggestionsBox, textarea: !!textarea });

    async function loadSuggestions() {
        if (!suggestionsBox || !textarea) return;
        
        suggestionsBox.innerHTML = '<span style="color:#64748b;font-size:12px;font-weight:600;display:flex;align-items:center;gap:6px;"><svg class="animate-spin" style="width:14px;height:14px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" style="opacity:0.25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity:0.75"></path></svg> Getting AI suggestions...</span>';

        try {
            const response = await fetch(suggestionsUrl);
            const data = await response.json();
            console.log('AI Suggestions:', data);

            if (data.suggestions && data.suggestions.length > 0) {
                suggestionsBox.innerHTML = '';
                data.suggestions.forEach(suggestion => {
                    const chip = document.createElement('button');
                    chip.type = 'button';
                    chip.className = 'suggestion-chip';
                    chip.textContent = suggestion;
                    chip.style.cssText = 'background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; padding:6px 14px; border-radius:10px; font-size:12.5px; font-weight:700; cursor:pointer; transition:all 0.2s; white-space:nowrap;';
                    
                    chip.onclick = () => {
                        textarea.value = suggestion;
                        textarea.focus();
                    };
                    suggestionsBox.appendChild(chip);
                });
            } else {
                suggestionsBox.innerHTML = '<span style="color:#94a3b8;font-size:12px;font-style:italic;">No suggestions available</span>';
            }
        } catch (e) {
            console.error('AI Error:', e);
            suggestionsBox.innerHTML = '';
        }
    }

    loadSuggestions();

    // AI Transformation logic (Formalize & Correct)
    document.querySelectorAll('.transform-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (!textarea) return;
            const currentText = textarea.value.trim();
            if (!currentText) return;

            console.log('AI Transformation: Starting...', btn.dataset.mode);
            const mode = btn.dataset.mode;
            const originalContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<svg class="animate-spin" style="width:14px;height:14px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" style="opacity:0.25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity:0.75"></path></svg>';

            try {
                const response = await fetch('{{ path('app_message_reformulate') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: currentText, mode: mode })
                });
                const data = await response.json();
                console.log('AI Transformation Result:', data);
                if (data.transformed) {
                    textarea.value = data.transformed;
                }
            } catch (e) {
                console.error('AI Transformation Error:', e);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        });
    });

    // Re-load suggestions after form submission
    const replyForm = document.getElementById('replyForm');
    if (replyForm) {
        replyForm.addEventListener('submit', function() {
            // Standard submit
        });
    }

    // AI Summary logic
    const summarizeBtn = document.getElementById('summarizeBtn');
    const summaryModal = document.getElementById('summaryModalOverlay');
    
    console.log('AI Summary: Initializing...', { btn: !!summarizeBtn, modal: !!summaryModal });

    // Admin Shortcuts (Abbreviations)
    const shortcuts = {
        '/done': 'Your ticket has been officially resolved. Thank you for choosing Fin-Dinari!',
        '/greeting': 'Hello {{ ticket.utilisateur.prenom }}, we are currently investigating your request and will get back to you as soon as possible.',
        '/moreinfo': 'Could you please provide additional details or a screenshot to help us better understand the situation?',
        '/wait': 'Your request has been escalated to our technical department. We appreciate your patience during this process.',
        '/verify': 'We have applied a correction. Could you please check if the issue is now resolved on your side?',
        '/sorry': 'Please accept our sincere apologies for the inconvenience caused and the delay in our response.'
    };

    textarea.addEventListener('input', function(e) {
        const value = textarea.value;
        const words = value.split(/\s+/);
        const lastWord = words[words.length - 1] === "" ? words[words.length - 2] : words[words.length - 1];
        
        // Only trigger if space was pressed and the word matches a shortcut
        if (e.inputType === 'insertText' && e.data === ' ') {
            const cursorPosition = textarea.selectionStart;
            const textBeforeCursor = value.substring(0, cursorPosition).trim();
            const lastWordBeforeSpace = textBeforeCursor.split(/\s+/).pop();

            if (shortcuts[lastWordBeforeSpace]) {
                const expansion = shortcuts[lastWordBeforeSpace];
                const newText = textBeforeCursor.substring(0, textBeforeCursor.length - lastWordBeforeSpace.length) + expansion + ' ';
                const textAfterCursor = value.substring(cursorPosition);
                
                textarea.value = newText + textAfterCursor;
                // Move cursor to after expansion
                const newPos = newText.length;
                textarea.setSelectionRange(newPos, newPos);
            }
        }
    });

    window.closeSummaryModal = function() {
        if (summaryModal) {
            summaryModal.style.display = 'none';
            summaryModal.style.opacity = '0';
        }
    };

    if (summarizeBtn) {
        summarizeBtn.addEventListener('click', async () => {
            console.log('AI Summary: Clicked');
            const originalContent = summarizeBtn.innerHTML;
            summarizeBtn.disabled = true;
            summarizeBtn.style.opacity = '0.7';
            summarizeBtn.innerHTML = '<svg class="animate-spin" style="width:14px;height:14px;margin-right:8px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" style="opacity:0.25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity:0.75"></path></svg> Analyzing...';

            try {
                const response = await fetch('{{ path('app_ticket_summary', {id: ticket.id}) }}');
                const data = await response.json();
                console.log('AI Summary Data:', data);
                
                if (data.problem || data.error) {
                    if (data.error) {
                        alert('Summary error: ' + data.error);
                        return;
                    }

                    document.getElementById('summaryProblem').textContent = data.problem || 'N/A';
                    document.getElementById('summaryProcess').textContent = data.process || 'N/A';
                    document.getElementById('summarySolution').textContent = data.solution || 'N/A';
                    document.getElementById('summaryState').textContent = data.state || 'N/A';
                    
                    const noteWrapper = document.getElementById('summaryNoteWrapper');
                    if (data.adaptive_note) {
                        document.getElementById('summaryNote').textContent = data.adaptive_note;
                        noteWrapper.style.display = 'block';
                    } else {
                        noteWrapper.style.display = 'none';
                    }
                    
                    if (summaryModal) {
                        summaryModal.style.display = 'flex';
                        setTimeout(() => summaryModal.style.opacity = '1', 10);
                    }
                }
            } catch (e) {
                console.error('AI Summary Error:', e);
                alert('Connection error while fetching summary.');
            } finally {
                summarizeBtn.disabled = false;
                summarizeBtn.style.opacity = '1';
                summarizeBtn.innerHTML = originalContent;
            }
        });
    }

    if (summaryModal) {
        summaryModal.addEventListener('click', (e) => {
            if (e.target === summaryModal) closeSummaryModal();
        });
    }

    // --- SLA Timer Logic ---
    const timers = document.querySelectorAll('.sla-timer');
    const serverTimeStr = '{{ "now"|date("c") }}';
    const serverNow = new Date(serverTimeStr);
    const clientNow = new Date();
    const timeOffset = serverNow.getTime() - clientNow.getTime();

    function formatDuration(totalSeconds) {
        const isNegative = totalSeconds < 0;
        const absSeconds = Math.abs(totalSeconds);
        const days = Math.floor(absSeconds / 86400);
        const hours = Math.floor((absSeconds % 86400) / 3600);
        const minutes = Math.floor((absSeconds % 3600) / 60);
        const seconds = absSeconds % 60;

        let text = isNegative ? '- ' : '';
        if (days > 0) text += days + 'd ';
        text += String(hours).padStart(2, '0') + 'h ';
        text += String(minutes).padStart(2, '0') + 'm ';
        text += String(seconds).padStart(2, '0') + 's';
        return text;
    }

    function updateTimer(element) {
        const deadlineString = element.dataset.deadline;
        const deadline = new Date(deadlineString);
        const now = new Date(Date.now() + timeOffset);
        const diff = deadline.getTime() - now.getTime();

        if (isNaN(deadline.getTime())) {
            element.textContent = 'Invalid SLA';
            element.className = 'sla-timer badge bg-dark';
            return;
        }

        const totalSeconds = Math.floor(diff / 1000);
        element.textContent = formatDuration(totalSeconds);

        if (totalSeconds <= 0) {
            element.className = 'sla-timer badge bg-danger';
        } else if (totalSeconds <= 3600) {
            element.className = 'sla-timer badge bg-danger';
        } else if (totalSeconds <= 4 * 3600) {
            element.className = 'sla-timer badge bg-warning text-dark';
        } else if (totalSeconds <= 24 * 3600) {
            element.className = 'sla-timer badge bg-info';
        } else {
            element.className = 'sla-timer badge bg-success';
        }
    }

    if (timers.length > 0) {
        timers.forEach(t => {
            updateTimer(t);
            setInterval(() => updateTimer(t), 1000);
        });
    }

    // --- AJAX Polling for new messages ---
    let lastMessageId = {{ messages|length > 0 ? messages|last.id : 0 }};
    // Using a numeric placeholder that Symfony will accept as an 'int' if required
    const fetchUrlPattern = "{{ path('app_ticket_fetch_new_messages', {id: ticket.id, lastId: 999999}) }}";

    function pollMessages() {
        const url = fetchUrlPattern.replace('999999', lastMessageId);
        
        fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => {
            if (!response.ok) throw new Error('Network response was not ok');
            return response.json();
        })
        .then(data => {
            if (data.count > 0) {
                console.log(`Chat Polling: Found ${data.count} new messages.`);
                const chatContainer = document.getElementById('chatContainer');
                const noMessagesPlaceholder = document.getElementById('noMessagesPlaceholder');
                
                if (noMessagesPlaceholder) {
                    noMessagesPlaceholder.remove();
                }
                
                // Append new messages
                chatContainer.insertAdjacentHTML('beforeend', data.html);
                
                // Update lastId
                lastMessageId = data.lastId;
                
                // Scroll to bottom
                chatContainer.scrollTop = chatContainer.scrollHeight;
            }
        })
        .catch(err => console.error('Chat Polling Error:', err));
    }

    // Check for new messages every 3 seconds
    setInterval(pollMessages, 3000);
});

async function translateMsgToFR(messageId, btn) {
    // If already translated → restore original
    if (btn.dataset.translated === '1') {
        document.getElementById('msg-text-' + messageId).innerHTML = btn.dataset.original;
        btn.innerHTML = btn.dataset.btnOriginal;
        btn.dataset.translated = '0';
        btn.style.color = '';
        return;
    }

    const originalHtml = btn.innerHTML;
    btn.dataset.btnOriginal = originalHtml;
    btn.innerHTML = '<svg viewBox="0 0 20 20" fill="currentColor" style="width:11px;height:11px;animation:spin 1s linear infinite"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg> Translating…';
    btn.disabled = true;
    try {
        const res = await fetch(`/message/${messageId}/translate`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await res.json();
        if (data.translated) {
            const msgEl = document.getElementById('msg-text-' + messageId);
            btn.dataset.original = msgEl.innerHTML; // save original HTML
            msgEl.innerHTML = data.translated.replace(/\n/g, '<br>');
            btn.innerHTML = '↩ Show original';
            btn.style.color = '#22c55e';
            btn.dataset.translated = '1';
            btn.disabled = false;
        } else {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
            alert('Translation failed: ' + (data.error || 'Unknown error'));
        }
    } catch(e) {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
    }
}
</script>

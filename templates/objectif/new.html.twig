<script>
(function () {

  /* ── STATE ─────────────────────────────────── */
  let step = 1;
  const TOTAL = 4;
  let selCat = '';
  let micRecognition = null;   // instance de SpeechRecognition
  let micListening = false;

  const catIcons = {
    'Voyage':     '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21 4 19.5 2.5S18 2 16.5 3.5L13 7 4.8 5.2C4.3 5.1 3.9 5.4 3.8 5.9l-.4 1.4c-.1.4.1.9.4 1.1L8 10.7l-3.5 3.5c-.5.5-.5 1.2 0 1.6l.7.7c.4.4 1.1.4 1.6 0L10 13l2.6 4.2c.2.4.7.6 1.1.4l1.4-.4c.5-.1.8-.5.7-1z"/></svg>',
    'Immobilier': '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
    'Véhicule':   '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
    'Formation':  '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
    'Urgences':   '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    'Autre':      '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:#0F6E56;fill:none;stroke-width:1.75"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>'
  };

  /* ── CATEGORY ────────────────────────────── */
  window.selectCat = function (btn) {
    document.querySelectorAll('.fn-cat-btn').forEach(b => b.classList.remove('sel'));
    btn.classList.add('sel');
    selCat = btn.dataset.cat;
    document.getElementById('pvCat').textContent = selCat;
    document.getElementById('pvIcon').innerHTML = catIcons[selCat] || catIcons['Autre'];
    syncPreview();
  };

  /* ── PREVIEW SYNC ────────────────────────── */
  window.syncPreview = function () {
    const titreEl   = document.getElementById('fn_titre');
    const montantEl = document.getElementById('fn_montant');
    const dureeEl   = document.getElementById('fn_duree');
    const dateEl    = document.getElementById('fn_date');
    const statutEl  = document.getElementById('fn_statut');

    const titre   = titreEl   ? titreEl.value.trim() : '';
    const montant = montantEl ? (parseFloat(montantEl.value) || 0) : 0;
    const duree   = dureeEl   ? (parseInt(dureeEl.value) || 0)    : 0;
    const dateVal = dateEl    ? dateEl.value : '';
    const statut  = statutEl  ? statutEl.options[statutEl.selectedIndex]?.text : 'Actif';

    document.getElementById('pvName').textContent = titre || 'Nouvel objectif';
    if (selCat) document.getElementById('pvCat').textContent = selCat;

    if (montant > 0) {
      document.getElementById('pvTotal').textContent = '/ ' + montant.toLocaleString('fr-TN') + ' TND';
      document.getElementById('pvNote').textContent  = 'Objectif défini — commencez à épargner !';
    } else {
      document.getElementById('pvTotal').textContent = '/ — TND';
      document.getElementById('pvNote').textContent  = 'Renseignez le montant pour voir l\'aperçu.';
    }

    document.getElementById('pvDuree').textContent = duree ? duree + ' mois' : '—';

    const mensuel = (montant > 0 && duree > 0) ? Math.round(montant / duree) : 0;
    document.getElementById('pvMensuel').textContent = mensuel ? mensuel.toLocaleString('fr-TN') + ' TND' : '—';

    /* confirmation panel */
    document.getElementById('cf-cat').textContent    = selCat || '—';
    document.getElementById('cf-titre').textContent  = titre || '—';
    document.getElementById('cf-statut').textContent = statut || '—';
    document.getElementById('cf-montant').textContent = montant ? montant.toLocaleString('fr-TN') + ' TND' : '—';
    document.getElementById('cf-duree').textContent  = duree ? duree + ' mois' : '—';
    document.getElementById('cf-mensuel').textContent = mensuel ? mensuel.toLocaleString('fr-TN') + ' TND / mois' : '—';

    if (dateVal) {
      const d = new Date(dateVal);
      document.getElementById('cf-date').textContent = d.toLocaleDateString('fr-FR', {day:'2-digit', month:'long', year:'numeric'});
    } else {
      document.getElementById('cf-date').textContent = '—';
    }
  };

  /* ── STEP MACHINE ────────────────────────── */
  function applyStep (n) {
    step = n;
    for (let i = 1; i <= TOTAL; i++) {
      const panel = document.getElementById('panel' + i);
      if (panel) panel.classList.toggle('active', i === n);

      const sn = document.getElementById('sn' + i);
      const sl = document.getElementById('sl' + i);
      if (!sn || !sl) continue;

      if (i < n) {
        sn.className = 'fn-step-num done';
        sn.innerHTML = '<svg style="width:12px;height:12px;stroke:#0F6E56;fill:none;stroke-width:3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
        sl.className = 'fn-step-label done';
      } else if (i === n) {
        sn.className = 'fn-step-num active';
        sn.textContent = i;
        sl.className = 'fn-step-label active';
      } else {
        sn.className = 'fn-step-num idle';
        sn.textContent = i;
        sl.className = 'fn-step-label idle';
      }

      const line = document.getElementById('line' + i);
      if (line) line.classList.toggle('active', i < n);
    }

    document.getElementById('btnBack').disabled = n === 1;
    document.getElementById('navMeta').textContent = 'Étape ' + n + ' / ' + TOTAL;

    const btnNext   = document.getElementById('btnNext');
    const btnSubmit = document.getElementById('btnSubmit');
    if (n === TOTAL) {
      btnNext.style.display   = 'none';
      btnSubmit.style.display = 'inline-flex';
      syncPreview();
    } else {
      btnNext.style.display   = 'inline-flex';
      btnSubmit.style.display = 'none';
    }
  }

  window.nextStep     = function () { if (step < TOTAL) applyStep(step + 1); };
  window.prevStep     = function () { if (step > 1)     applyStep(step - 1); };
  window.jumpToStep   = function (n) { if (n < step)    applyStep(n); };

  /* ── SPEECH TO TEXT (microphone) ─────────── */
 window.toggleMic = function () {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const micBtn = document.getElementById('micBtn');
  const micHint = document.getElementById('micHint');
  // Sélecteur robuste pour le champ titre
  const inputTitle = document.querySelector('[name$="[titre]"]') || document.getElementById('fn_titre');

  if (!SpeechRecognition) {
    if (micHint) micHint.textContent = 'Votre navigateur ne supporte pas la reconnaissance vocale.';
    return;
  }

  if (micListening && micRecognition) {
    micRecognition.stop();
    return;
  }

  micRecognition = new SpeechRecognition();
  micRecognition.lang = 'fr-FR';
  micRecognition.interimResults = false;
  micRecognition.continuous = false;

  micRecognition.onstart = function() {
    micListening = true;
    if (micBtn) micBtn.classList.add('on');
    if (micHint) {
      micHint.textContent = '🎙️ Écoute en cours... Parlez maintenant.';
      micHint.classList.add('on');
    }
  };

  micRecognition.onresult = function(event) {
    const transcript = event.results[0][0].transcript;
    if (inputTitle) {
      inputTitle.value = transcript;
      // Forcer les événements
      inputTitle.dispatchEvent(new Event('input', { bubbles: true }));
      inputTitle.dispatchEvent(new Event('change', { bubbles: true }));
      if (typeof syncPreview === 'function') syncPreview();
      inputTitle.focus();
      // Vérification différée
      setTimeout(() => {
        if (inputTitle.value !== transcript) {
          inputTitle.value = transcript;
          inputTitle.dispatchEvent(new Event('input', { bubbles: true }));
          if (typeof syncPreview === 'function') syncPreview();
        }
      }, 50);
    }
    if (micHint) {
      micHint.textContent = '✅ Titre saisi : "' + transcript + '"';
      micHint.classList.remove('on');
    }
    if (micBtn) micBtn.classList.remove('on');
    micListening = false;
  };

  micRecognition.onerror = function(event) {
    console.error('Erreur reconnaissance vocale', event.error);
    if (micHint) {
      micHint.textContent = '❌ Erreur : ' + (event.error === 'not-allowed' ? 'Microphone non autorisé' : event.error);
      micHint.classList.remove('on');
    }
    if (micBtn) micBtn.classList.remove('on');
    micListening = false;
  };

  micRecognition.onend = function() {
    if (micBtn) micBtn.classList.remove('on');
    micListening = false;
    if (micHint && micHint.textContent.includes('Écoute en cours')) {
      micHint.textContent = 'Cliquez sur le micro pour dicter le titre vocalement.';
      micHint.classList.remove('on');
    }
  };

  micRecognition.start();
};



  /* ── INIT ────────────────────────────────── */
  const dateEl = document.getElementById('fn_date');
  if (dateEl && !dateEl.value) dateEl.valueAsDate = new Date();

  applyStep(1);
})();
</script>

{% endblock %}
{% extends 'base.html.twig' %}
{% block title %}Profil — {{ userData.userName }}{% endblock %}

{% block body %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Syne:wght@600;700;800;900&display=swap');

  :root {
    --green: #1a9e6e;
    --green-dark: #157a55;
    --green-light: #e1f5ee;
    --gold: #e9a000;
    --gold-light: #faeeda;
    --border: #e8e8e4;
    --bg: #f7f7f5;
    --surface: #fff;
    --text: #111;
    --muted: #999;
  }
  * { box-sizing: border-box; }

  .detail-page {
    padding: 2rem;
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    min-height: 100vh;
  }

  /* ── NAV ── */
  .det-nav { display: flex; gap: 8px; margin-bottom: 1.75rem; flex-wrap: wrap; }
  .det-nav a {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: #555; text-decoration: none;
    padding: 6px 14px; border: 0.5px solid #e0e0dc;
    border-radius: 10px; background: #fff; transition: all .2s;
  }
  .det-nav a:hover { background: #f5f5f3; color: #111; border-color: #ccc; }

  /* ══════════════════════════════════
     HERO PROFIL — magazine style
  ══════════════════════════════════ */
  .profile-hero {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    height: 340px;
    margin-bottom: 2rem;
    display: flex; align-items: flex-end;
  }

  .profile-hero-bg {
    position: absolute; inset: 0; z-index: 0;
    {% if userData.rank == 1 %}
      background: linear-gradient(145deg, #a8e6cc 0%, #1a9e6e 50%, #0a5e3f 100%);
    {% elseif userData.rank == 2 %}
      background: linear-gradient(145deg, #e0e0e0 0%, #b0b0b0 50%, #707070 100%);
    {% elseif userData.rank == 3 %}
      background: linear-gradient(145deg, #e8c8a0 0%, #cd7f32 50%, #7a4a1a 100%);
    {% else %}
      background: linear-gradient(145deg, #b8d4f0 0%, #378ADD 50%, #1a5a9e 100%);
    {% endif %}
  }

  /* Decorative sparkle dots */
  .profile-hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,255,255,.85) 1.5px, transparent 1.5px),
      radial-gradient(circle, rgba(255,255,255,.5) 1px, transparent 1px);
    background-size: 80px 80px, 45px 45px;
    background-position: 20px 25px, 42px 50px;
  }

  /* Big decorative ring */
  .profile-hero-ring {
    position: absolute; z-index: 1;
    width: 420px; height: 420px;
    border-radius: 50%;
    border: 60px solid rgba(255,255,255,.08);
    top: -120px; right: -80px;
  }
  .profile-hero-ring2 {
    position: absolute; z-index: 1;
    width: 200px; height: 200px;
    border-radius: 50%;
    border: 30px solid rgba(255,255,255,.06);
    bottom: -60px; left: 60px;
  }

  /* Dark gradient at bottom for text */
  .profile-hero::before {
    content: ''; position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.1) 55%, transparent 100%);
  }

  /* Rank number watermark */
  .profile-hero-rank-watermark {
    position: absolute; top: 16px; right: 24px; z-index: 3;
    font-family: 'Syne', sans-serif;
    font-size: 120px; font-weight: 900;
    color: rgba(255,255,255,.1); line-height: 1;
  }

  .profile-hero-content {
    position: relative; z-index: 3;
    padding: 2rem 2.5rem;
    display: flex; align-items: flex-end; gap: 2rem;
    width: 100%; flex-wrap: wrap;
  }

  .profile-avatar-wrap { position: relative; flex-shrink: 0; }
  .profile-avatar {
    width: 88px; height: 88px; border-radius: 50%;
    background: rgba(255,255,255,.2);
    backdrop-filter: blur(8px);
    border: 3px solid rgba(255,255,255,.5);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif;
    font-size: 32px; font-weight: 900; color: #fff;
    box-shadow: 0 8px 24px rgba(0,0,0,.3);
  }
  .profile-medal-badge {
    position: absolute; bottom: -6px; right: -6px;
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    border: 3px solid #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,.25);
    {% if userData.rank == 1 %}background: linear-gradient(135deg, #FFD700, #FFA500);
    {% elseif userData.rank == 2 %}background: linear-gradient(135deg, #E8E8E8, #C0C0C0);
    {% elseif userData.rank == 3 %}background: linear-gradient(135deg, #CD7F32, #B87333);
    {% else %}background: linear-gradient(135deg, #667eea, #764ba2);{% endif %}
  }

  .profile-info { flex: 1; min-width: 0; }
  .profile-name {
    font-family: 'Syne', sans-serif;
    font-size: 36px; font-weight: 900; color: #fff;
    line-height: 1; margin-bottom: 6px;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
  }
  .profile-sub { font-size: 13px; color: rgba(255,255,255,.75); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .profile-sub-sep { color: rgba(255,255,255,.3); }

  .profile-kpis { display: flex; gap: 12px; flex-wrap: wrap; }
  .profile-kpi {
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(6px);
    border: 0.5px solid rgba(255,255,255,.25);
    border-radius: 12px; padding: 10px 16px;
    min-width: 90px;
  }
  .profile-kpi-val {
    font-family: 'Syne', sans-serif;
    font-size: 22px; font-weight: 800; color: #fff; line-height: 1;
  }
  .profile-kpi-lbl { font-size: 10px; color: rgba(255,255,255,.65); text-transform: uppercase; letter-spacing: .6px; margin-top: 3px; }

  /* ── MEDAL SHOWCASE ── */
  .medal-showcase {
    display: flex; gap: 12px;
    background: var(--surface); border: 0.5px solid var(--border);
    border-radius: 18px; padding: 1.5rem;
    margin-bottom: 1.75rem; align-items: center;
    flex-wrap: wrap;
  }
  .medal-main {
    width: 80px; height: 80px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 40px; flex-shrink: 0;
    {% if userData.rank == 1 %}
      background: linear-gradient(135deg, #FFD700, #FFA500);
      box-shadow: 0 6px 24px rgba(255,215,0,.45);
    {% elseif userData.rank == 2 %}
      background: linear-gradient(135deg, #E8E8E8, #A8A8A8);
      box-shadow: 0 6px 20px rgba(168,168,168,.4);
    {% elseif userData.rank == 3 %}
      background: linear-gradient(135deg, #CD7F32, #B87333);
      box-shadow: 0 6px 20px rgba(205,127,50,.4);
    {% else %}
      background: linear-gradient(135deg, #667eea, #764ba2);
      box-shadow: 0 6px 20px rgba(102,126,234,.3);
    {% endif %}
    animation: pulse-medal 2.5s ease-in-out infinite;
  }
  @keyframes pulse-medal {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  .medal-text { flex: 1; }
  .medal-title {
    font-family: 'Syne', sans-serif;
    font-size: 20px; font-weight: 800; color: var(--text); margin-bottom: 4px;
  }
  .medal-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }

  .medal-rank-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 16px; border-radius: 20px;
    font-size: 13px; font-weight: 700;
    {% if userData.rank == 1 %}background: #fffbe8; color: #92600a; border: 0.5px solid #f5d060;
    {% elseif userData.rank == 2 %}background: #f5f5f5; color: #555; border: 0.5px solid #ccc;
    {% elseif userData.rank == 3 %}background: #fdf0e8; color: #7a3e1a; border: 0.5px solid #e0a87a;
    {% else %}background: var(--green-light); color: #085041; border: 0.5px solid #9fe1cb;{% endif %}
  }

  /* ── SECTION ── */
  .section-label {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Syne', sans-serif; font-size: 18px;
    font-weight: 700; color: var(--text); margin-bottom: 1.25rem;
  }
  .section-label::after { content: ''; flex: 1; height: 0.5px; background: var(--border); }

  /* ── OBJECTIF CARDS ── */
  .obj-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .obj-card-detail {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    transition: box-shadow .25s, transform .2s;
  }
  .obj-card-detail:hover { box-shadow: 0 10px 28px rgba(0,0,0,.09); transform: translateY(-3px); }

  .obj-card-top {
    height: 120px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    background: linear-gradient(135deg, #d0f0e4, #e8f7f0);
  }
  .obj-card-top-icon { font-size: 48px; filter: drop-shadow(0 4px 10px rgba(0,0,0,.1)); }
  .obj-card-top-badge {
    position: absolute; top: 10px; right: 10px;
    background: var(--green-light); color: #085041;
    font-size: 10px; font-weight: 700; padding: 3px 10px;
    border-radius: 20px; backdrop-filter: blur(4px);
  }
  .obj-card-top-accent {
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px; background: linear-gradient(90deg, var(--green), #2dd4a0);
  }

  .obj-card-body { padding: 1rem; }
  .obj-card-title {
    font-weight: 700; font-size: 15px; color: var(--text);
    margin-bottom: 8px; line-height: 1.3;
  }
  .obj-card-meta { font-size: 11px; color: var(--muted); margin-bottom: 12px; display: flex; gap: 12px; flex-wrap: wrap; }

  .obj-prog-bar { height: 6px; background: #eee; border-radius: 3px; overflow: hidden; margin-bottom: 4px; }
  .obj-prog-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--green), #2dd4a0); width: 100%; }
  .obj-prog-info { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 12px; }

  .obj-amounts { display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px; }
  .obj-amt-collected { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; color: var(--green); }
  .obj-amt-sep { color: #ccc; font-size: 13px; }
  .obj-amt-target { font-size: 13px; color: var(--muted); }

  .obj-contribs {
    background: #f8f8f6; border-radius: 10px; padding: 10px 12px;
  }
  .obj-contribs-title { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; font-weight: 600; }
  .contrib-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--surface); border: 0.5px solid var(--border);
    border-radius: 8px; padding: 4px 10px;
    font-size: 11px; color: #555; margin: 3px;
  }
  .contrib-chip-amt { font-weight: 600; color: var(--green); }

  .obj-success-banner {
    background: linear-gradient(135deg, var(--green-light), #c8f0de);
    border-radius: 10px; padding: 10px 14px;
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 600; color: #085041;
    margin-top: 8px;
  }

  /* ── STATS ROW ── */
  .stats-row {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 10px; margin-bottom: 2rem;
  }
  .stat-card {
    background: var(--surface); border: 0.5px solid var(--border);
    border-radius: 14px; padding: 1rem 1.25rem;
    text-align: center; transition: box-shadow .2s, transform .2s;
  }
  .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.07); }
  .stat-card-icon { font-size: 28px; margin-bottom: 6px; }
  .stat-card-val { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 900; color: var(--green); }
  .stat-card-lbl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-top: 2px; }

  /* ── TIMELINE ── */
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 7px; top: 0; bottom: 0; width: 1.5px; background: linear-gradient(to bottom, var(--green), transparent); }
  .timeline-item { position: relative; margin-bottom: 1rem; }
  .timeline-dot { position: absolute; left: -2rem; top: 4px; width: 14px; height: 14px; border-radius: 50%; background: var(--green); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--green); }
  .timeline-content { background: var(--surface); border: 0.5px solid var(--border); border-radius: 12px; padding: .75rem 1rem; }
  .timeline-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
  .timeline-meta  { font-size: 11px; color: var(--muted); }

  @media (max-width: 640px) {
    .detail-page { padding: 1rem; }
    .profile-hero { height: auto; min-height: 280px; }
    .profile-hero-content { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .profile-name { font-size: 26px; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .obj-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="detail-page">

  {# ── NAV ── #}
  <div class="det-nav">
    <a href="{{ path('top_contributions', {userId: userData.userId}) }}">← Top contributeurs</a>
    <a href="{{ path('objectif_index') }}">🎯 Mes objectifs</a>
  </div>

  {# ══ HERO MAGAZINE ══ #}
  <div class="profile-hero">
    <div class="profile-hero-bg"></div>
    <div class="profile-hero-ring"></div>
    <div class="profile-hero-ring2"></div>
    <div class="profile-hero-rank-watermark">#{{ userData.rank }}</div>

    <div class="profile-hero-content">
      <div class="profile-avatar-wrap">
        <div class="profile-avatar">{{ userData.userName|slice(0,2)|upper }}</div>
        <div class="profile-medal-badge">
          {% if userData.rank == 1 %}🥇{% elseif userData.rank == 2 %}🥈{% elseif userData.rank == 3 %}🥉{% else %}🎖{% endif %}
        </div>
      </div>

      <div class="profile-info">
        <div class="profile-name">{{ userData.userName }}</div>
        <div class="profile-sub">
          <span>📍 {{ userData.pays }}</span>
          <span class="profile-sub-sep">·</span>
          <span>Rang #{{ userData.rank }}</span>
        </div>

        {% set totalCollected = 0 %}{% set totalContribs = 0 %}
        {% for item in userData.objectifsAtteints %}
          {% set totalCollected = totalCollected + item.stats.totalCollected %}
          {% set totalContribs  = totalContribs  + item.stats.contributionCount %}
        {% endfor %}

        <div class="profile-kpis">
          <div class="profile-kpi">
            <div class="profile-kpi-val">{{ userData.objectifsAtteints|length }}</div>
            <div class="profile-kpi-lbl">Objectifs atteints</div>
          </div>
          <div class="profile-kpi">
            <div class="profile-kpi-val">{{ totalContribs }}</div>
            <div class="profile-kpi-lbl">Contributions</div>
          </div>
          <div class="profile-kpi">
            <div class="profile-kpi-val">{{ totalCollected|number_format(0, ',', ' ') }}</div>
            <div class="profile-kpi-lbl">Total collecté</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ── MEDAL SHOWCASE ── #}
  <div class="medal-showcase">
    <div class="medal-main">
      {% if userData.rank == 1 %}🥇{% elseif userData.rank == 2 %}🥈{% elseif userData.rank == 3 %}🥉{% else %}🎖{% endif %}
    </div>
    <div class="medal-text">
      <div class="medal-title">
        {% if userData.rank == 1 %}Médaille d'or — Champion absolu
        {% elseif userData.rank == 2 %}Médaille d'argent — Vice-champion
        {% elseif userData.rank == 3 %}Médaille de bronze — 3ème au classement
        {% else %}Contributeur actif — Rang #{{ userData.rank }}
        {% endif %}
      </div>
      <div class="medal-desc">
        {% if userData.rank == 1 %}{{ userData.userName }} est le meilleur contributeur de la plateforme avec {{ userData.objectifsAtteints|length }} objectifs atteints et {{ totalCollected|number_format(0,',',' ') }} collectés au total.
        {% else %}{{ userData.userName }} fait partie des meilleurs contributeurs de la plateforme avec {{ userData.objectifsAtteints|length }} objectif{{ userData.objectifsAtteints|length > 1 ? 's' : '' }} atteint{{ userData.objectifsAtteints|length > 1 ? 's' : '' }}.
        {% endif %}
      </div>
    </div>
    <div class="medal-rank-pill">
      {% if userData.rank == 1 %}🥇{% elseif userData.rank == 2 %}🥈{% elseif userData.rank == 3 %}🥉{% else %}🎖{% endif %}
      Rang #{{ userData.rank }}
    </div>
  </div>

  {# ── STATS ── #}
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-card-icon">🎯</div>
      <div class="stat-card-val">{{ userData.objectifsAtteints|length }}</div>
      <div class="stat-card-lbl">Objectifs atteints</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon">📦</div>
      <div class="stat-card-val">{{ totalContribs }}</div>
      <div class="stat-card-lbl">Contributions</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-icon">💰</div>
      <div class="stat-card-val">{{ totalCollected|number_format(0,',',' ') }}</div>
      <div class="stat-card-lbl">Total collecté</div>
    </div>
  </div>

  {# ── OBJECTIFS DÉTAIL ── #}
  <div class="section-label">🏆 Objectifs réalisés</div>

  {% if userData.objectifsAtteints|length == 0 %}
    <div style="text-align:center;padding:3rem;color:var(--muted);background:var(--surface);border-radius:16px;border:0.5px dashed #ddd;">
      Aucun objectif atteint pour le moment.
    </div>
  {% else %}
    <div class="obj-grid">
      {% for item in userData.objectifsAtteints %}
        {% set icon = '🏆' %}
        {% if 'voyage' in item.objectif.titre|lower or 'vacances' in item.objectif.titre|lower %}{% set icon = '✈️' %}
        {% elseif 'voiture' in item.objectif.titre|lower or 'auto' in item.objectif.titre|lower %}{% set icon = '🚗' %}
        {% elseif 'maison' in item.objectif.titre|lower or 'appart' in item.objectif.titre|lower %}{% set icon = '🏠' %}
        {% elseif 'etude' in item.objectif.titre|lower or 'école' in item.objectif.titre|lower %}{% set icon = '📚' %}
        {% elseif 'retraite' in item.objectif.titre|lower %}{% set icon = '🌿' %}
        {% elseif 'invest' in item.objectif.titre|lower %}{% set icon = '📈' %}
        {% endif %}

        <div class="obj-card-detail">
          <div class="obj-card-top">
            <div class="obj-card-top-accent"></div>
            <div class="obj-card-top-icon">{{ icon }}</div>
            <div class="obj-card-top-badge">✔ Atteint</div>
          </div>
          <div class="obj-card-body">
            <div class="obj-card-title">{{ item.objectif.titre }}</div>
            <div class="obj-card-meta">
              <span>📅 {{ item.objectif.dateDebut|date('d/m/Y') }}</span>
              <span>⏱ {{ item.objectif.duree }} mois</span>
            </div>
            <div class="obj-amounts">
              <span class="obj-amt-collected">{{ item.stats.totalCollected|number_format(0,',', ' ') }}</span>
              <span class="obj-amt-sep">/</span>
              <span class="obj-amt-target">{{ item.stats.targetAmount|number_format(0,',',' ') }}</span>
            </div>
            <div class="obj-prog-bar"><div class="obj-prog-fill"></div></div>
            <div class="obj-prog-info"><span>Progression</span><span style="color:var(--green);font-weight:600;">100% ✓</span></div>

            {% if item.contributions is defined and item.contributions|length > 0 %}
              <div class="obj-contribs">
                <div class="obj-contribs-title">{{ item.stats.contributionCount }} contribution{{ item.stats.contributionCount > 1 ? 's' : '' }}</div>
                {% for c in item.contributions|slice(0, 4) %}
                  <span class="contrib-chip">
                    <span class="contrib-chip-amt">{{ c.montant|number_format(0,',',' ') }}</span>
                    <span style="color:#ccc;">·</span>
                    <span>{{ c.date|date('d/m/y') }}</span>
                  </span>
                {% endfor %}
                {% if item.contributions|length > 4 %}
                  <span class="contrib-chip" style="color:var(--muted);">+{{ item.contributions|length - 4 }} autres</span>
                {% endif %}
              </div>
            {% else %}
              <div class="obj-contribs">
                <div class="obj-contribs-title">{{ item.stats.contributionCount }} contribution{{ item.stats.contributionCount > 1 ? 's' : '' }}</div>
                <span style="font-size:11px;color:var(--muted);">Total : {{ item.stats.totalCollected|number_format(2,',',' ') }}</span>
              </div>
            {% endif %}

            <div class="obj-success-banner">🏆 Objectif atteint avec succès !</div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# ── TIMELINE ── #}
  {% if userData.objectifsAtteints|length > 0 %}
    <div class="section-label">📅 Historique chronologique</div>
    <div class="timeline">
      {% for item in userData.objectifsAtteints|sort((a,b) => b.objectif.dateDebut <=> a.objectif.dateDebut) %}
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-title">🏆 {{ item.objectif.titre }}</div>
            <div class="timeline-meta">Démarré le {{ item.objectif.dateDebut|date('d/m/Y') }} · {{ item.stats.totalCollected|number_format(0,',',' ') }} collectés · {{ item.stats.contributionCount }} contribution{{ item.stats.contributionCount > 1 ? 's' : '' }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}

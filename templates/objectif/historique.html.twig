{% extends 'base.html.twig' %}
{% block title %}Historique & Prédictions{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@600;700&display=swap');

  .hist-page {
    padding: 2rem;
    max-width: 900px;
    margin: auto;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Nav ── */
  .hist-nav { display: flex; gap: 8px; margin-bottom: 2rem; flex-wrap: wrap; }
  .hist-nav a {
    font-size: 12px; color: #555; text-decoration: none;
    padding: 6px 14px; border: 0.5px solid #e0e0dc;
    border-radius: 20px; background: #fff; transition: all .2s;
    display: inline-flex; align-items: center; gap: 6px;
    font-weight: 500;
  }
  .hist-nav a:hover { background: #f5f5f3; color: #1a1a1a; border-color: #ccc; }
  .hist-nav a.active { background: #1a9e6e; color: #fff; border-color: #1a9e6e; }

  /* ── Header ── */
  .hist-badge {
    display: inline-block; background: #e1f5ee; color: #085041;
    font-size: 11px; font-weight: 600; padding: 4px 12px;
    border-radius: 20px; margin-bottom: 10px; letter-spacing: .04em;
  }
  .hist-title { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 700; color: #1a1a1a; margin: 0 0 6px; }
  .hist-sub   { font-size: 14px; color: #888; margin-bottom: 2rem; }

  /* ── Summary strip ── */
  .hist-summary {
    display: flex; gap: 10px; margin-bottom: 2rem; flex-wrap: wrap;
  }
  .summary-chip {
    flex: 1; min-width: 120px;
    background: #f9f9f7; border: 0.5px solid #e0e0dc;
    border-radius: 12px; padding: .75rem 1rem;
    text-align: center;
  }
  .summary-chip-val { font-size: 22px; font-weight: 700; color: #1a1a1a; }
  .summary-chip-lbl { font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }

  /* ── Section labels ── */
  .section-label {
    font-size: 11px; font-weight: 600; color: #aaa;
    text-transform: uppercase; letter-spacing: .06em;
    margin: 2rem 0 1rem;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::after { content: ''; flex: 1; height: 0.5px; background: #e8e8e4; }

  /* ── Prediction cards ── */
  .pred-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }

  .pred-card {
    background: #fff; border: 0.5px solid #e0e0dc;
    border-radius: 18px; overflow: hidden; transition: all .25s;
  }
  .pred-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.07); border-color: #c8c8c4; transform: translateY(-1px); }

  .pred-top {
    padding: 1rem 1.25rem;
    background: #f9f9f7;
    border-bottom: 0.5px solid #ebebeb;
  }
  .pred-title { font-size: 14px; font-weight: 600; color: #1a1a1a; margin-bottom: 6px; }
  .pred-pct   { font-size: 12px; color: #888; }

  .prog-bg   { height: 6px; background: #e8e8e4; border-radius: 10px; overflow: hidden; margin-top: 10px; }
  .prog-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #e9a000, #f5c842); transition: width .4s ease; }

  .pred-body { padding: 1rem 1.25rem; }

  .pred-date-box {
    background: linear-gradient(135deg, #f0faf6, #f9fffe);
    border: 0.5px solid #c8eadc;
    border-radius: 12px;
    padding: .875rem 1rem; margin-bottom: 12px; text-align: center;
  }
  .pred-date-val { font-size: 22px; font-weight: 700; color: #0d5c42; letter-spacing: -.5px; }
  .pred-date-sub { font-size: 11px; color: #5a8c78; margin-top: 3px; }

  .pred-row {
    display: flex; justify-content: space-between;
    font-size: 12px; color: #888; padding: 5px 0;
    border-bottom: 0.5px solid #f0f0ee;
  }
  .pred-row:last-of-type { border-bottom: none; }
  .pred-row span:last-child { font-weight: 600; color: #333; }

  .conf-badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 10px; font-weight: 600;
    padding: 4px 10px; border-radius: 20px; margin-top: 10px;
  }
  .conf-haute   { background: #e1f5ee; color: #0f6e56; }
  .conf-moyenne { background: #faeeda; color: #854f0b; }
  .conf-faible  { background: #f5f5f3; color: #888; }

  .no-pred {
    background: #f9f9f7; border: 0.5px dashed #e0e0dc;
    border-radius: 10px; padding: 1rem;
    font-size: 12px; color: #aaa; text-align: center;
  }

  /* ── AI Advisor ── */
  .advisor-section {
    background: #fff;
    border: 0.5px solid #c8eadc;
    border-radius: 20px;
    overflow: hidden;
    margin-top: 2rem;
  }

  .advisor-header {
    display: flex; align-items: center; gap: 14px;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, #f0faf6 0%, #f5fff9 100%);
    border-bottom: 0.5px solid #d8f0e4;
  }
  .advisor-icon {
    width: 42px; height: 42px; background: #1a9e6e;
    border-radius: 12px; display: flex; align-items: center;
    justify-content: center; font-size: 20px; flex-shrink: 0;
  }
  .advisor-title { font-size: 16px; font-weight: 700; color: #0d5c42; }
  .advisor-sub   { font-size: 12px; color: #5a8c78; margin-top: 2px; }

  .advisor-body { padding: 1.25rem 1.5rem; }

  /* ── Speech-to-text ── */
  .stt-block { margin-bottom: 1.25rem; }
  .stt-label {
    font-size: 12px; font-weight: 600; color: #555;
    text-transform: uppercase; letter-spacing: .04em;
    margin-bottom: 8px; display: block;
  }
  .stt-input-wrap { position: relative; }
  .stt-textarea {
    width: 100%; box-sizing: border-box;
    padding: 10px 44px 10px 14px;
    border: 0.5px solid #c8eadc; border-radius: 12px;
    background: #f9fffe; font-size: 13px;
    font-family: 'DM Sans', sans-serif; color: #1a1a1a;
    resize: vertical; min-height: 72px; line-height: 1.5;
    outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .stt-textarea:focus {
    border-color: #1a9e6e;
    box-shadow: 0 0 0 3px rgba(26,158,110,.1);
  }
  .stt-textarea::placeholder { color: #aaa; }

  .mic-btn {
    position: absolute; top: 10px; right: 10px;
    width: 28px; height: 28px;
    background: #e1f5ee; border: 0.5px solid #9fe1cb;
    border-radius: 8px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all .2s; padding: 0;
  }
  .mic-btn:hover { background: #c8eadc; border-color: #1a9e6e; }
  .mic-btn.recording {
    background: #fcebeb; border-color: #f09595;
    animation: mic-pulse 1s ease-in-out infinite;
  }
  .mic-btn svg { width: 14px; height: 14px; stroke: #0f6e56; }
  .mic-btn.recording svg { stroke: #a32d2d; }

  @keyframes mic-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(192,57,43,.3); }
    50%       { box-shadow: 0 0 0 6px rgba(192,57,43,0); }
  }

  .mic-status {
    font-size: 11px; color: #1a9e6e; margin-top: 5px;
    min-height: 16px; display: flex; align-items: center; gap: 5px;
  }
  .mic-status.error { color: #a32d2d; }

  .mic-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #1a9e6e; display: none;
    animation: blink .8s ease-in-out infinite;
  }
  .mic-status.active .mic-dot { display: inline-block; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

  /* ── Advisor form row ── */
  .advisor-form-row {
    display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;
    margin-top: 1rem;
  }
  .advisor-field { display: flex; flex-direction: column; gap: 6px; }
  .advisor-field-label { font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: .04em; }

  .advisor-select {
    flex: 1; min-width: 160px; padding: 9px 14px;
    border: 0.5px solid #c8eadc; border-radius: 10px;
    background: #fff; font-size: 13px; color: #1a1a1a;
    font-family: 'DM Sans', sans-serif; outline: none;
    appearance: none; cursor: pointer; transition: border-color .2s;
  }
  .advisor-select:focus { border-color: #1a9e6e; box-shadow: 0 0 0 3px rgba(26,158,110,.1); }

  .advisor-input {
    width: 110px; padding: 9px 14px;
    border: 0.5px solid #c8eadc; border-radius: 10px;
    background: #fff; font-size: 13px; color: #1a1a1a;
    font-family: 'DM Sans', sans-serif; outline: none;
    transition: border-color .2s;
  }
  .advisor-input:focus { border-color: #1a9e6e; box-shadow: 0 0 0 3px rgba(26,158,110,.1); }

  .advisor-btn {
    padding: 9px 20px; background: #1a9e6e; color: #fff;
    border: none; border-radius: 10px; font-size: 13px;
    font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif;
    transition: background .2s; white-space: nowrap;
  }
  .advisor-btn:hover   { background: #158a5e; }
  .advisor-btn:active  { background: #0f6e56; }
  .advisor-btn:disabled { background: #a8d5c4; cursor: wait; }

  /* ── Advisor result ── */
  .advisor-result {
    background: #f9fffe; border: 0.5px solid #c8eadc;
    border-radius: 14px; padding: 1.25rem;
    display: none; margin-top: 1rem;
    animation: slide-in .2s ease;
  }
  .advisor-result.visible { display: block; }
  @keyframes slide-in { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }

  .advisor-result-date { font-size: 26px; font-weight: 700; color: #0d5c42; letter-spacing: -.5px; }
  .advisor-result-sub  { font-size: 12px; color: #5a8c78; margin: 3px 0 14px; }
  .advisor-result-rows { display: flex; gap: 16px; flex-wrap: wrap; }
  .advisor-result-col  { flex: 1; min-width: 90px; background: #fff; border: 0.5px solid #e0e0dc; border-radius: 10px; padding: .75rem 1rem; }
  .advisor-result-val  { font-size: 16px; font-weight: 700; color: #1a9e6e; }
  .advisor-result-lbl  { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }

  .advisor-error {
    color: #a32d2d; font-size: 12px; padding: 9px 14px;
    background: #fcebeb; border: 0.5px solid #f09595;
    border-radius: 8px; display: none; margin-top: 8px;
  }
  .advisor-error.visible { display: block; }

  /* ── Timeline ── */
  .timeline { display: flex; flex-direction: column; }
  .tl-item  { display: flex; gap: 18px; }
  .tl-line  { display: flex; flex-direction: column; align-items: center; }
  .tl-dot   {
    width: 14px; height: 14px; border-radius: 50%;
    background: #1a9e6e; flex-shrink: 0; margin-top: 6px;
    box-shadow: 0 0 0 4px #e1f5ee;
  }
  .tl-connector { width: 2px; background: #e0e0dc; flex: 1; margin: 5px 0; min-height: 24px; }
  .tl-item:last-child .tl-connector { display: none; }

  .tl-card {
    flex: 1; background: #fff; border: 0.5px solid #e0e0dc;
    border-radius: 16px; padding: 1.1rem 1.25rem;
    margin-bottom: 14px; transition: box-shadow .2s;
  }
  .tl-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }

  .tl-date  { font-size: 11px; color: #aaa; margin-bottom: 5px; }
  .tl-title { font-size: 15px; font-weight: 700; color: #1a1a1a; }
  .tl-meta  { font-size: 12px; color: #888; margin-top: 5px; }

  .tl-stats { display: flex; gap: 20px; margin-top: 14px; flex-wrap: wrap; }
  .tl-stat-val { font-size: 18px; font-weight: 700; color: #1a9e6e; }
  .tl-stat-lbl { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }

  .badge-done {
    display: inline-block; background: #e1f5ee; color: #0f6e56;
    font-size: 10px; font-weight: 700; padding: 3px 10px;
    border-radius: 20px; margin-left: 8px; vertical-align: middle;
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center; padding: 3rem;
    color: #ccc; font-size: 14px;
    background: #f9f9f7; border-radius: 14px;
    border: 0.5px dashed #e0e0dc;
  }

  @media (max-width: 620px) {
    .hist-page { padding: 1rem; }
    .pred-cards { grid-template-columns: 1fr; }
    .tl-stats { gap: 12px; }
    .advisor-form-row { flex-direction: column; }
    .advisor-input { width: 100%; }
    .advisor-select { min-width: 100%; }
  }
</style>

<div class="hist-page">

  {# ── Nav ── #}
  <div class="hist-nav">
    <a href="{{ path('objectif_index') }}">← Mes objectifs</a>
    <a href="{{ path('objectif_historique') }}" class="active">📈 Historique & Prédictions</a>
    <a href="{{ path('top_contributions') }}">🏆 Top contributeurs</a>
  </div>

  {# ── Header ── #}
  <div class="hist-badge">📈 Suivi</div>
  <h1 class="hist-title">Historique & Prédictions</h1>
  <p class="hist-sub">Suivez vos objectifs et simulez votre progression</p>

  {# ── Summary chips ── #}
  <div class="hist-summary">
    <div class="summary-chip">
      <div class="summary-chip-val">{{ historique|length }}</div>
      <div class="summary-chip-lbl">Atteints</div>
    </div>
    <div class="summary-chip">
      <div class="summary-chip-val">{{ enCours|length }}</div>
      <div class="summary-chip-lbl">En cours</div>
    </div>
    <div class="summary-chip">
      <div class="summary-chip-val">{{ (historique|length + enCours|length) }}</div>
      <div class="summary-chip-lbl">Total</div>
    </div>
  </div>

  {# ══════════════════════════════════════════
     SECTION 1 : OBJECTIFS EN COURS + PRÉDICTION
  ══════════════════════════════════════════ #}
  <div class="section-label">🔮 Prédictions — objectifs en cours</div>

  {% if enCours is empty %}
    <div class="empty-state">Aucun objectif en cours.</div>
  {% else %}
    <div class="pred-cards">
      {% for item in enCours %}
        {% set pred = item.stats.prediction %}
        {% set pct  = item.stats.progressPct|round %}
        <div class="pred-card">
          <div class="pred-top">
            <div class="pred-title">{{ item.objectif.titre }}</div>
            <div class="pred-pct">
              {{ item.stats.totalCollected|number_format(0, ',', ' ') }}
              / {{ item.stats.targetAmount|number_format(0, ',', ' ') }} — {{ pct }}%
            </div>
            <div class="prog-bg">
              <div class="prog-fill" style="width: {{ pct }}%"></div>
            </div>
          </div>
          <div class="pred-body">
            {% if pred %}
              <div class="pred-date-box">
                <div class="pred-date-val">{{ pred.predictedDate|date('d/m/Y') }}</div>
                <div class="pred-date-sub">Date estimée d'atteinte</div>
              </div>
              <div class="pred-row">
                <span>⏳ Jours restants</span>
                <span>{{ pred.daysNeeded }} j</span>
              </div>
              <div class="pred-row">
                <span>⚡ Vélocité moyenne</span>
                <span>{{ pred.velocityPerDay|number_format(2, ',', ' ') }} / j</span>
              </div>
              <div class="pred-row">
                <span>🎯 Reste à collecter</span>
                <span>{{ pred.remaining|number_format(0, ',', ' ') }}</span>
              </div>
              <span class="conf-badge conf-{{ pred.confidence }}">
                Confiance :
                {% if pred.confidence == 'haute' %}🟢 Haute
                {% elseif pred.confidence == 'moyenne' %}🟡 Moyenne
                {% else %}⚪ Faible{% endif %}
              </span>
            {% else %}
              <div class="no-pred">
                Pas encore assez de contributions pour estimer une date.
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# ══════════════════════════════════════════
     SECTION 2 : CONSEILLER IA avec Speech-to-Text
  ══════════════════════════════════════════ #}
  {% if enCours is not empty %}
  <div class="advisor-section">

    <div class="advisor-header">
      <div class="advisor-icon">🤖</div>
      <div>
        <div class="advisor-title">Conseiller IA</div>
        <div class="advisor-sub">Décrivez votre objectif à voix haute, saisissez un montant journalier et obtenez une prédiction</div>
      </div>
    </div>

    <div class="advisor-body">

      {# ── Champ description avec micro ── #}
      <div class="stt-block">
        <span class="stt-label">🎙 Décrivez votre objectif (optionnel)</span>
        <div class="stt-input-wrap">
          <textarea
            class="stt-textarea"
            id="advisorDescription"
            placeholder="Ex : Je veux économiser pour acheter une voiture avant l'été…"
            rows="3"
          ></textarea>
          <button type="button" class="mic-btn" id="micBtnDesc" title="Dicter la description" onclick="toggleMic('advisorDescription', 'micBtnDesc', 'micStatusDesc')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="2" width="6" height="11" rx="3"/>
              <path d="M19 10a7 7 0 01-14 0"/>
              <line x1="12" y1="19" x2="12" y2="22"/>
              <line x1="8" y1="22" x2="16" y2="22"/>
            </svg>
          </button>
        </div>
        <div class="mic-status" id="micStatusDesc">
          <span class="mic-dot"></span>
          <span class="mic-text"></span>
        </div>
      </div>

      {# ── Sélecteur + montant + bouton ── #}
      <div class="advisor-form-row">
        <div class="advisor-field" style="flex: 2; min-width: 160px;">
          <span class="advisor-field-label">Objectif</span>
          <select class="advisor-select" id="advisorObjectifSelect">
            <option value="">— Choisir un objectif —</option>
            {% for item in enCours %}
              <option value="{{ item.objectif.id }}">{{ item.objectif.titre }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="advisor-field">
          <span class="advisor-field-label">Montant / jour</span>
          <input
            type="number"
            class="advisor-input"
            id="advisorAmount"
            placeholder="Ex : 50"
            min="0.01"
            step="0.01"
          />
        </div>

        <button class="advisor-btn" id="advisorBtn" onclick="simulateContribution()">
          ✦ Simuler
        </button>
      </div>

      <div class="advisor-error" id="advisorError"></div>

      <div class="advisor-result" id="advisorResult">
        <div class="advisor-result-date" id="advisorDate"></div>
        <div class="advisor-result-sub" id="advisorDateSub"></div>
        <div class="advisor-result-rows">
          <div class="advisor-result-col">
            <div class="advisor-result-val" id="advisorDays"></div>
            <div class="advisor-result-lbl">Jours nécessaires</div>
          </div>
          <div class="advisor-result-col">
            <div class="advisor-result-val" id="advisorRemaining"></div>
            <div class="advisor-result-lbl">Reste à collecter</div>
          </div>
          <div class="advisor-result-col">
            <div class="advisor-result-val" id="advisorConf"></div>
            <div class="advisor-result-lbl">Confiance</div>
          </div>
        </div>
      </div>

    </div>{# /advisor-body #}
  </div>
  {% endif %}

  {# ══════════════════════════════════════════
     SECTION 3 : HISTORIQUE DES OBJECTIFS ATTEINTS
  ══════════════════════════════════════════ #}
  <div class="section-label">✅ Historique des objectifs atteints</div>

  {% if historique is empty %}
    <div class="empty-state">Aucun objectif atteint pour le moment.</div>
  {% else %}
    <div class="timeline">
      {% for item in historique %}
        <div class="tl-item">
          <div class="tl-line">
            <div class="tl-dot"></div>
            <div class="tl-connector"></div>
          </div>
          <div class="tl-card">
            <div class="tl-date">
              {% if item.dateAtteinte %}
                Atteint le {{ item.dateAtteinte|date('d/m/Y') }}
              {% else %}
                Date inconnue
              {% endif %}
            </div>
            <div>
              <span class="tl-title">{{ item.objectif.titre }}</span>
              <span class="badge-done">✓ Terminé</span>
            </div>
            <div class="tl-meta">
              Démarré le {{ item.objectif.dateDebut|date('d/m/Y') }}
              · Durée cible : {{ item.objectif.duree }} mois
            </div>
            <div class="tl-stats">
              <div>
                <div class="tl-stat-val">{{ item.stats.totalCollected|number_format(0, ',', ' ') }}</div>
                <div class="tl-stat-lbl">Collecté</div>
              </div>
              <div>
                <div class="tl-stat-val">{{ item.stats.contributionCount }}</div>
                <div class="tl-stat-lbl">Contributions</div>
              </div>
              <div>
                {% if item.dureeReelle is defined and item.dureeReelle is not null %}
                  <div class="tl-stat-val">{{ item.dureeReelle }} j</div>
                {% else %}
                  <div class="tl-stat-val">—</div>
                {% endif %}
                <div class="tl-stat-lbl">Durée réelle</div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>{# /hist-page #}

<script>
/* ─────────────────────────────────────────
   Speech-to-Text (Web Speech API)
───────────────────────────────────────── */
let recognition = null;
let activeField  = null;
let activeMicBtn = null;

function toggleMic(fieldId, btnId, statusId) {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

  if (!SpeechRecognition) {
    const s = document.getElementById(statusId);
    s.className = 'mic-status error';
    s.querySelector('.mic-text').textContent = 'Votre navigateur ne supporte pas la reconnaissance vocale.';
    return;
  }

  const btn    = document.getElementById(btnId);
  const status = document.getElementById(statusId);
  const field  = document.getElementById(fieldId);

  // Stop if already recording this field
  if (recognition && activeField === fieldId) {
    recognition.stop();
    return;
  }

  // Stop any existing recognition
  if (recognition) recognition.stop();

  recognition = new SpeechRecognition();
  recognition.lang = 'fr-FR';
  recognition.continuous = false;
  recognition.interimResults = true;

  activeField  = fieldId;
  activeMicBtn = btnId;

  recognition.onstart = () => {
    btn.classList.add('recording');
    status.className = 'mic-status active';
    status.querySelector('.mic-text').textContent = 'Écoute en cours…';
  };

  recognition.onresult = (e) => {
    const transcript = Array.from(e.results)
      .map(r => r[0].transcript).join('');
    field.value = transcript;
    if (e.results[0].isFinal) {
      status.querySelector('.mic-text').textContent = 'Transcription terminée ✓';
    }
  };

  recognition.onerror = (e) => {
    btn.classList.remove('recording');
    status.className = 'mic-status error';
    const msgs = {
      'not-allowed': 'Microphone refusé. Vérifiez les permissions.',
      'no-speech':   'Aucune parole détectée.',
      'network':     'Erreur réseau.',
    };
    status.querySelector('.mic-text').textContent = msgs[e.error] || 'Erreur : ' + e.error;
  };

  recognition.onend = () => {
    btn.classList.remove('recording');
    if (status.querySelector('.mic-text').textContent === 'Écoute en cours…') {
      status.className = 'mic-status';
      status.querySelector('.mic-text').textContent = '';
    }
    recognition = null;
    activeField  = null;
    activeMicBtn = null;
  };

  recognition.start();
}

/* ─────────────────────────────────────────
   Simulation
───────────────────────────────────────── */
async function simulateContribution() {
  const selectEl = document.getElementById('advisorObjectifSelect');
  const amountEl = document.getElementById('advisorAmount');
  const resultEl = document.getElementById('advisorResult');
  const errorEl  = document.getElementById('advisorError');
  const btn      = document.getElementById('advisorBtn');

  const objectifId = selectEl.value;
  const amount     = parseFloat(amountEl.value);

  resultEl.classList.remove('visible');
  errorEl.classList.remove('visible');

  if (!objectifId) {
    errorEl.textContent = 'Veuillez sélectionner un objectif.';
    errorEl.classList.add('visible');
    return;
  }
  if (!amount || amount <= 0) {
    errorEl.textContent = 'Veuillez saisir un montant journalier valide.';
    errorEl.classList.add('visible');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Calcul…';

  try {
    const formData = new FormData();
    formData.append('montant_quotidien', amount);

    const resp = await fetch(`/objectif/${objectifId}/simuler`, {
      method: 'POST',
      body: formData,
    });

    const data = await resp.json();

    if (!resp.ok || data.error) {
      errorEl.textContent = data.error || 'Une erreur est survenue.';
      errorEl.classList.add('visible');
      return;
    }

    const confLabel = { haute: '🟢 Haute', moyenne: '🟡 Moyenne', faible: '⚪ Faible' };

    if (data.message) {
      document.getElementById('advisorDate').textContent    = '🎉 Objectif déjà atteint !';
      document.getElementById('advisorDateSub').textContent = '';
      document.getElementById('advisorDays').textContent      = '—';
      document.getElementById('advisorRemaining').textContent = '—';
      document.getElementById('advisorConf').textContent      = '—';
    } else {
      document.getElementById('advisorDate').textContent    = data.predictedDate;
      document.getElementById('advisorDateSub').textContent = `En contribuant ${amount.toFixed(2)} par jour`;
      document.getElementById('advisorDays').textContent      = `${data.daysNeeded} j`;
      document.getElementById('advisorRemaining').textContent =
        Number(data.remaining).toLocaleString('fr-FR', { minimumFractionDigits: 0 });
      document.getElementById('advisorConf').textContent = confLabel[data.confidence] || data.confidence;
    }

    resultEl.classList.add('visible');

  } catch (e) {
    errorEl.textContent = 'Erreur réseau. Veuillez réessayer.';
    errorEl.classList.add('visible');
  } finally {
    btn.disabled = false;
    btn.textContent = '✦ Simuler';
  }
}
</script>
{% endblock %}

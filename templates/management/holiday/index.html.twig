{% extends 'management/dashboard.html.twig' %}

{% block title %}Holidays - Fin-Dinari{% endblock %}

{% set active_tab = 'holiday' %}

{% block content %}

<turbo-frame id="content-frame">

    {# Header #}
    <div class="row mb-4 align-items-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-1" style="color: #26474E;">
                <i class="fas fa-calendar-check me-2"></i>Upcoming Holidays
            </h1>
            <p class="text-muted mb-0">Plan your spending around upcoming holidays and traditions</p>
        </div>
    </div>

    {# Country Selector #}
    <div class="row mb-4">
        <div class="col-lg-5">
            <div class="card border-0 rounded-4" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                <div class="rounded-top-4 p-4 text-white" style="background: #26474E;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 opacity-75 small text-uppercase fw-semibold">Select Country</p>
                            <h4 class="fw-bold mb-0">Find Holidays</h4>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px; height:48px; background: rgba(255,255,255,0.2);">
                            <i class="fas fa-globe fa-lg"></i>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #26474E;">Country</label>
                        <select id="holidayCountrySelect" class="form-select"
                                onchange="fetchHolidays()"
                                style="border-color: #76CDCD; color: #26474E; background-color: #f8f9fa;">
                            <option value="">Loading countries...</option>
                        </select>
                    </div>
                    <div class="rounded-3 p-3" style="background: #e8f5f5;">
                        <p class="small mb-0" style="color: #26474E;">
                            <i class="fas fa-info-circle me-1" style="color: #2CCED2;"></i>
                            Shows holidays in the next <strong>30 days</strong> with AI-powered spending recommendations
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {# Stats Cards #}
        <div class="col-lg-7" id="holidayStats" style="display: none;">
            <div class="row g-3 h-100">
                <div class="col-md-4">
                    <div class="rounded-4 p-3 text-white h-100 d-flex flex-column justify-content-center"
                         style="background: #F27438;">
                        <p class="mb-1 opacity-75 small fw-semibold text-uppercase">Upcoming</p>
                        <h2 class="fw-bold mb-0" id="holidayCount">0</h2>
                        <p class="mb-0 opacity-75 small">holidays in 30 days</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="rounded-4 p-3 text-white h-100 d-flex flex-column justify-content-center"
                         style="background: #2d6a4f;">
                        <p class="mb-1 opacity-75 small fw-semibold text-uppercase">Next Holiday</p>
                        <h4 class="fw-bold mb-0" id="nextHolidayName" style="font-size: 16px;">—</h4>
                        <p class="mb-0 opacity-75 small" id="nextHolidayDate">—</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="rounded-4 p-3 text-white h-100 d-flex flex-column justify-content-center"
                         style="background: #2CCED2;">
                        <p class="mb-1 opacity-75 small fw-semibold text-uppercase">Days Until</p>
                        <h2 class="fw-bold mb-0" id="daysUntil">—</h2>
                        <p class="mb-0 opacity-75 small">next holiday</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Loading State #}
    <div id="holidayLoading" style="display: none;">
        <div class="card border-0 rounded-4 d-flex align-items-center justify-content-center"
             style="box-shadow: 0 4px 20px rgba(0,0,0,0.08); min-height: 200px;">
            <div class="text-center">
                <div class="spinner-border mb-3" style="color: #F27438;"></div>
                <p class="text-muted fw-bold">Fetching holidays...</p>
            </div>
        </div>
    </div>

    {# Empty State #}
    <div id="holidayEmpty">
        <div class="card border-0 rounded-4 d-flex align-items-center justify-content-center"
             style="box-shadow: 0 4px 20px rgba(0,0,0,0.08); min-height: 250px; border: 2px dashed #76CDCD;">
            <div class="text-center p-4">
                <i class="fas fa-calendar-check fa-3x mb-3" style="color: #2CCED2;"></i>
                <h5 style="color: #26474E;">Select a country</h5>
                <p class="text-muted">Choose a country to see upcoming holidays and AI spending recommendations</p>
            </div>
        </div>
    </div>

    {# No Holidays Found #}
    <div id="holidayNone" style="display: none;">
        <div class="card border-0 rounded-4 d-flex align-items-center justify-content-center"
             style="box-shadow: 0 4px 20px rgba(0,0,0,0.08); min-height: 200px;">
            <div class="text-center p-4">
                <i class="fas fa-calendar-xmark fa-3x mb-3" style="color: #999;"></i>
                <h5 style="color: #26474E;">No holidays in the next 30 days</h5>
                <p class="text-muted">There are no public holidays coming up in this period</p>
            </div>
        </div>
    </div>

    {# Holidays List #}
    <div id="holidayList" style="display: none;">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 rounded-4" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3" style="color: #26474E;">
                            <i class="fas fa-calendar-days me-2" style="color: #F27438;"></i>
                            Holidays in the Next 30 Days
                        </h5>
                        <div id="holidayCards" class="d-flex gap-3 flex-wrap"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# AI Recommendations #}
    <div id="holidayRecommendations" style="display: none;">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 rounded-4" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                    <div class="rounded-top-4 p-4 text-white" style="background: #F27438;">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">
                                <i class="fas fa-robot me-2"></i>AI Spending Predictions
                            </h5>
                            <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.2);">
                                <i class="fas fa-sparkles me-1"></i>Powered by Groq AI
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4" id="holidayAIContent">
                        <div class="text-center py-4">
                            <div class="spinner-border mb-3" style="color: #F27438;"></div>
                            <p class="text-muted fw-bold">AI is analyzing holidays and traditions...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</turbo-frame>

<style>
    .rounded-top-4 { border-radius: 1rem 1rem 0 0 !important; }
    .rounded-4 { border-radius: 1rem !important; }
    .holiday-card {
        flex: 1;
        min-width: 220px;
        max-width: 300px;
        padding: 20px;
        border-radius: 14px;
        background: white;
        border: 1px solid #e8f5f5;
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
    }
    .holiday-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        border-color: #F27438;
    }
    .holiday-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(135deg, #F27438, #2CCED2);
    }
    .expense-card {
        border-radius: 12px;
        padding: 16px;
        background: #f8f9fa;
        transition: all 0.2s;
    }
    .expense-card:hover {
        background: #e8f5f5;
    }
    #holidayCountrySelect:focus {
        border-color: #F27438 !important;
        box-shadow: 0 0 0 0.2rem rgba(242,116,56,0.2) !important;
    }
    #holidayCountrySelect option {
        color: #26474E;
        background-color: white;
    }
</style>

<script>
const GROQ_API_KEY = '{{ groq_api_key }}';
let countryCodes = {};

// Nager.Date supported countries
const nagerCountries = {
    'AD': 'Andorra', 'AL': 'Albania', 'AR': 'Argentina', 'AT': 'Austria', 'AU': 'Australia',
    'AX': 'Åland Islands', 'BA': 'Bosnia and Herzegovina', 'BB': 'Barbados', 'BE': 'Belgium',
    'BG': 'Bulgaria', 'BJ': 'Benin', 'BO': 'Bolivia', 'BR': 'Brazil', 'BS': 'Bahamas',
    'BW': 'Botswana', 'BY': 'Belarus', 'BZ': 'Belize', 'CA': 'Canada', 'CH': 'Switzerland',
    'CL': 'Chile', 'CN': 'China', 'CO': 'Colombia', 'CR': 'Costa Rica', 'CU': 'Cuba',
    'CY': 'Cyprus', 'CZ': 'Czechia', 'DE': 'Germany', 'DK': 'Denmark', 'DO': 'Dominican Republic',
    'EC': 'Ecuador', 'EE': 'Estonia', 'EG': 'Egypt', 'ES': 'Spain', 'FI': 'Finland',
    'FO': 'Faroe Islands', 'FR': 'France', 'GA': 'Gabon', 'GB': 'United Kingdom', 'GD': 'Grenada',
    'GL': 'Greenland', 'GM': 'Gambia', 'GR': 'Greece', 'GT': 'Guatemala', 'GY': 'Guyana',
    'HN': 'Honduras', 'HR': 'Croatia', 'HT': 'Haiti', 'HU': 'Hungary', 'ID': 'Indonesia',
    'IE': 'Ireland', 'IM': 'Isle of Man', 'IS': 'Iceland', 'IT': 'Italy', 'JE': 'Jersey',
    'JM': 'Jamaica', 'JP': 'Japan', 'KR': 'South Korea', 'LI': 'Liechtenstein', 'LS': 'Lesotho',
    'LT': 'Lithuania', 'LU': 'Luxembourg', 'LV': 'Latvia', 'MA': 'Morocco', 'MC': 'Monaco',
    'MD': 'Moldova', 'ME': 'Montenegro', 'MG': 'Madagascar', 'MK': 'North Macedonia',
    'MN': 'Mongolia', 'MT': 'Malta', 'MX': 'Mexico', 'MZ': 'Mozambique', 'NA': 'Namibia',
    'NE': 'Niger', 'NG': 'Nigeria', 'NI': 'Nicaragua', 'NL': 'Netherlands', 'NO': 'Norway',
    'NZ': 'New Zealand', 'PA': 'Panama', 'PE': 'Peru', 'PG': 'Papua New Guinea', 'PH': 'Philippines',
    'PL': 'Poland', 'PR': 'Puerto Rico', 'PT': 'Portugal', 'PY': 'Paraguay', 'RO': 'Romania',
    'RS': 'Serbia', 'RU': 'Russia', 'RW': 'Rwanda', 'SE': 'Sweden', 'SG': 'Singapore',
    'SI': 'Slovenia', 'SJ': 'Svalbard', 'SK': 'Slovakia', 'SM': 'San Marino', 'SR': 'Suriname',
    'SV': 'El Salvador', 'TN': 'Tunisia', 'TR': 'Turkey', 'UA': 'Ukraine', 'US': 'United States',
    'UY': 'Uruguay', 'VA': 'Vatican City', 'VE': 'Venezuela', 'VN': 'Vietnam',
    'ZA': 'South Africa', 'ZW': 'Zimbabwe'
};

// Load countries into dropdown
function loadHolidayCountries() {
    const select = document.getElementById('holidayCountrySelect');
    select.innerHTML = '<option value="">-- Choose a country --</option>';

    const sorted = Object.entries(nagerCountries).sort((a, b) => a[1].localeCompare(b[1]));

    sorted.forEach(([code, name]) => {
        const option = document.createElement('option');
        option.value = code;
        option.textContent = name;
        select.appendChild(option);
    });
}

// Fetch holidays from Nager.Date API
async function fetchHolidays() {
    const countryCode = document.getElementById('holidayCountrySelect').value;
    if (!countryCode) return;

    const countryName = nagerCountries[countryCode];

    // Show loading
    document.getElementById('holidayEmpty').style.display = 'none';
    document.getElementById('holidayNone').style.display = 'none';
    document.getElementById('holidayList').style.display = 'none';
    document.getElementById('holidayStats').style.display = 'none';
    document.getElementById('holidayRecommendations').style.display = 'none';
    document.getElementById('holidayLoading').style.display = 'block';

    try {
        const year = new Date().getFullYear();
        const response = await fetch(`https://date.nager.at/api/v3/PublicHolidays/${year}/${countryCode}`);
        const allHolidays = await response.json();

        // Filter holidays in the next 30 days
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const thirtyDaysLater = new Date(today);
        thirtyDaysLater.setDate(thirtyDaysLater.getDate() + 30);

        const upcoming = allHolidays.filter(h => {
            const hDate = new Date(h.date);
            return hDate >= today && hDate <= thirtyDaysLater;
        });

        document.getElementById('holidayLoading').style.display = 'none';

        if (upcoming.length === 0) {
            document.getElementById('holidayNone').style.display = 'block';
            return;
        }

        // Update stats
        document.getElementById('holidayCount').textContent = upcoming.length;
        const nextHoliday = upcoming[0];
        document.getElementById('nextHolidayName').textContent = nextHoliday.localName || nextHoliday.name;
        const nextDate = new Date(nextHoliday.date);
        document.getElementById('nextHolidayDate').textContent = nextDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
        const diffDays = Math.ceil((nextDate - today) / (1000 * 60 * 60 * 24));
        document.getElementById('daysUntil').textContent = diffDays === 0 ? 'Today!' : diffDays;

        document.getElementById('holidayStats').style.display = 'block';

        // Display holiday cards
        const cardsContainer = document.getElementById('holidayCards');
        cardsContainer.innerHTML = '';

        upcoming.forEach(holiday => {
            const hDate = new Date(holiday.date);
            const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const dayName = days[hDate.getDay()];
            const formattedDate = hDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
            const daysLeft = Math.ceil((hDate - today) / (1000 * 60 * 60 * 24));

            cardsContainer.innerHTML += `
                <div class="holiday-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <p class="small text-muted mb-0">${dayName}, ${formattedDate}</p>
                            <h6 class="fw-bold mb-0" style="color: #26474E;">${holiday.localName || holiday.name}</h6>
                        </div>
                        <span class="badge rounded-pill px-2 py-1"
                              style="background: ${daysLeft === 0 ? '#fde8e8' : '#e8f5f5'}; 
                                     color: ${daysLeft === 0 ? '#c0392b' : '#26474E'}; font-size: 11px;">
                            ${daysLeft === 0 ? 'Today!' : daysLeft + 'd left'}
                        </span>
                    </div>
                    <p class="small text-muted mb-0">
                        <i class="fas fa-tag me-1" style="color: #F27438;"></i>${holiday.name}
                    </p>
                    ${holiday.types ? '<p class="small mb-0 mt-1"><span class="badge rounded-pill px-2 py-1" style="background: #fff3ee; color: #F27438; font-size: 10px;">' + holiday.types.join(', ') + '</span></p>' : ''}
                </div>
            `;
        });

        document.getElementById('holidayList').style.display = 'block';

        // Get AI recommendations
        await getHolidayRecommendations(upcoming, countryName, countryCode);

    } catch (error) {
        console.error('Holiday fetch error:', error);
        document.getElementById('holidayLoading').style.display = 'none';
        document.getElementById('holidayEmpty').style.display = 'block';
    }
}

// Get AI spending recommendations for holidays
async function getHolidayRecommendations(holidays, countryName, countryCode) {
    const container = document.getElementById('holidayAIContent');
    container.innerHTML = `
        <div class="text-center py-4">
            <div class="spinner-border mb-3" style="color: #F27438;"></div>
            <p class="text-muted fw-bold">AI is analyzing holidays and local traditions...</p>
        </div>
    `;
    document.getElementById('holidayRecommendations').style.display = 'block';

    const holidayList = holidays.map(h => `- ${h.localName || h.name} (${h.name}) on ${h.date}`).join('\n');

    const prompt = `You are a smart financial advisor for a budgeting app called Fin-Dinari. The user is in ${countryName} (${countryCode}).

Here are the upcoming public holidays in the next 30 days:
${holidayList}

For EACH holiday, provide specific spending predictions based on the local traditions and culture of ${countryName}. Think about what people in ${countryName} specifically do and spend on during each holiday.

Respond ONLY with a valid JSON array. No markdown, no backticks, no explanation. Just the JSON array.
Each object must have:
- "holiday": the holiday name
- "date": the date
- "icon": a Font Awesome icon (like "fa-gift", "fa-utensils", "fa-mosque", "fa-church", "fa-tree", "fa-flag", "fa-cake-candles", "fa-people-group", "fa-moon", "fa-star", "fa-heart", "fa-music")
- "color": a hex color matching the holiday mood
- "traditions": one sentence about what people in ${countryName} traditionally do
- "expenses": array of 3-4 objects each with "item" (what to spend on), "priority" ("essential", "recommended", or "optional"), and "estimate" (rough cost range in local currency)
- "savingTip": one practical tip to save money during this holiday`;

    try {
        const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + GROQ_API_KEY,
            },
            body: JSON.stringify({
                model: 'llama-3.3-70b-versatile',
                messages: [{ role: 'user', content: prompt }],
                temperature: 0.7,
                max_tokens: 2000,
            })
        });

        const data = await response.json();
        let text = data.choices[0].message.content.trim();
        text = text.replace(/```json/g, '').replace(/```/g, '').trim();

        const recommendations = JSON.parse(text);

        container.innerHTML = '';

        recommendations.forEach(rec => {
            let expensesHtml = '';
            if (rec.expenses && rec.expenses.length > 0) {
                rec.expenses.forEach(exp => {
                    const priorityColor = exp.priority === 'essential' ? '#c0392b' : exp.priority === 'recommended' ? '#F27438' : '#2d6a4f';
                    const priorityBg = exp.priority === 'essential' ? '#fde8e8' : exp.priority === 'recommended' ? '#fff3ee' : '#e8f5e9';
                    expensesHtml += `
                        <div class="d-flex justify-content-between align-items-center mb-2 p-2 rounded-3" style="background: white;">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge rounded-pill px-2 py-1" style="background: ${priorityBg}; color: ${priorityColor}; font-size: 10px;">
                                    ${exp.priority}
                                </span>
                                <span class="small fw-bold" style="color: #26474E;">${exp.item}</span>
                            </div>
                            <span class="small fw-bold" style="color: #F27438;">${exp.estimate}</span>
                        </div>
                    `;
                });
            }

            container.innerHTML += `
                <div class="expense-card mb-3">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 48px; height: 48px; background: ${rec.color}20; flex-shrink: 0;">
                                <i class="fas ${rec.icon}" style="color: ${rec.color}; font-size: 18px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0" style="color: #26474E;">${rec.holiday}</h6>
                                <p class="small text-muted mb-0">
                                    <i class="fas fa-calendar me-1"></i>${rec.date}
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="rounded-3 p-2 mb-3" style="background: #e8f5f5;">
                        <p class="small mb-0" style="color: #26474E;">
                            <i class="fas fa-people-group me-1" style="color: #2CCED2;"></i>
                            <strong>Tradition:</strong> ${rec.traditions}
                        </p>
                    </div>

                    <p class="small fw-bold mb-2" style="color: #26474E;">
                        <i class="fas fa-receipt me-1" style="color: #F27438;"></i>Expected Expenses:
                    </p>
                    ${expensesHtml}

                    <div class="rounded-3 p-2 mt-2" style="background: #e8f5e9;">
                        <p class="small mb-0" style="color: #2d6a4f;">
                            <i class="fas fa-piggy-bank me-1"></i>
                            <strong>Saving Tip:</strong> ${rec.savingTip}
                        </p>
                    </div>
                </div>
            `;
        });

        container.innerHTML += `
            <div class="text-end mt-2">
                <span class="badge rounded-pill px-3 py-2" style="background: #e8f5f5; color: #26474E;">
                    <i class="fas fa-robot me-1"></i>Powered by Groq AI
                </span>
            </div>
        `;

    } catch (error) {
        console.error('AI Error:', error);
        container.innerHTML = `
            <div class="d-flex gap-3 align-items-start p-3 rounded-3" style="background: #fff3ee;">
                <i class="fas fa-exclamation-circle" style="color: #F27438; margin-top: 2px;"></i>
                <div>
                    <h6 class="fw-bold mb-1" style="color: #26474E;">AI Recommendations Unavailable</h6>
                    <p class="text-muted small mb-0">Could not generate spending predictions. Please try again later.</p>
                </div>
            </div>
        `;
    }
}

// Initialize
document.addEventListener('DOMContentLoaded', loadHolidayCountries);
</script>

{% endblock %}
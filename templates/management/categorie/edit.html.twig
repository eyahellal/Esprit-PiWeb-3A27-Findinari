{% extends 'base.html.twig' %}

{% block title %}Edit {{ categorie.nom }} - Fin-Dinari{% endblock %}

{% block body %}

<section class="page-header bg-tertiary">
    <div class="container">
        <div class="row">
            <div class="col-8 mx-auto text-center">
                <h2 class="mb-3 text-capitalize">Edit Category</h2>
                <ul class="list-inline breadcrumbs text-capitalize" style="font-weight:500">
                    <li class="list-inline-item"><a href="{{ path('app_home') }}">Home</a></li>
                    <li class="list-inline-item">/ &nbsp; <a href="{{ path('app_services') }}">Services</a></li>
                    <li class="list-inline-item">/ &nbsp; <a href="{{ path('app_categorie_index') }}">Categories</a></li>
                    <li class="list-inline-item">/ &nbsp; Edit</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="shadow rounded p-5 bg-white">
                    <h3 class="mb-4">Edit Category: {{ categorie.nom }}</h3>

                    {{ form_start(form) }}

                        <div class="mb-3">
                            {{ form_label(form.nom, 'Category Name', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger">{{ form_errors(form.nom) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '3'}}) }}
                            <div class="text-danger">{{ form_errors(form.description) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.statut, 'Status', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                            <div class="text-danger">{{ form_errors(form.statut) }}</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.color, 'Color', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.color, {'attr': {'class': 'form-control form-control-color w-100'}}) }}
                                <div class="text-danger">{{ form_errors(form.color) }}</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.icon, 'Icon', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.icon, {'attr': {'class': 'form-select'}}) }}
                                <div class="text-danger">{{ form_errors(form.icon) }}</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('app_categorie_index') }}" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Update Category
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}
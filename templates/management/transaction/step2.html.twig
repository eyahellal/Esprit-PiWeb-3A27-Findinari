{% extends 'base.html.twig' %}
{% block title %}New Transaction - Step 2{% endblock %}

{% block body %}
<section class="page-header" style="background: #e8f5f5;">
    <div class="container">
        <div class="row">
            <div class="col-8 mx-auto text-center">
                <h2 class="mb-3" style="color: #26474E;">New Transaction</h2>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">

        {# Progress Bar #}
        <div class="row mb-5">
            <div class="col-lg-6 mx-auto">
                <div class="d-flex align-items-center justify-content-center">
                    <div class="text-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto text-white"
                             style="width:50px; height:50px; background: #2d6a4f;">
                            <i class="fas fa-check"></i>
                        </div>
                        <p class="small fw-bold mt-2 mb-0" style="color: #2d6a4f;">Wallet</p>
                    </div>
                    <div style="height:3px; width:80px; background: #2d6a4f; margin: 0 8px;"></div>
                    <div class="text-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto text-white"
                             style="width:50px; height:50px; background: #F27438; box-shadow: 0 4px 12px rgba(242,116,56,0.4);">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <p class="small fw-bold mt-2 mb-0" style="color: #F27438;">Type</p>
                    </div>
                    <div style="height:3px; width:80px; background: #e0e0e0; margin: 0 8px;"></div>
                    <div class="text-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto"
                             style="width:50px; height:50px; background: #f5f5f5; color: #999;">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <p class="small fw-bold mt-2 mb-0" style="color: #999;">Details</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 rounded-4" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">

                    <div class="rounded-top-4 p-4 text-white" style="background: #F27438;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 opacity-75 small text-uppercase fw-semibold">Step 2 of 3</p>
                                <h4 class="fw-bold mb-0">Transaction Type</h4>
                            </div>
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:48px; height:48px; background: rgba(255,255,255,0.2);">
                                <i class="fas fa-exchange-alt fa-lg"></i>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <p class="text-muted mb-4">Is this transaction an income or an expense?</p>

                        <form method="post" action="{{ path('app_transaction_new_step2') }}">
                            <div class="row g-4 mb-4">

                                {# Income #}
                                <div class="col-md-6">
                                    <input type="radio" name="type" id="type_income"
                                           value="income" class="d-none type-radio">
                                    <label for="type_income"
                                           class="type-option w-100 rounded-4 p-4 text-center"
                                           style="border: 2px solid #e0e0e0; cursor: pointer; transition: all 0.2s;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                                             style="width:70px; height:70px; background: #e8f5e9;">
                                            <i class="fas fa-arrow-up fa-2x" style="color: #2d6a4f;"></i>
                                        </div>
                                        <h5 class="fw-bold mb-1" style="color: #2d6a4f;">Income</h5>
                                        <p class="text-muted small mb-0">Money coming in to your wallet</p>
                                    </label>
                                </div>

                                {# Expense #}
                                <div class="col-md-6">
                                    <input type="radio" name="type" id="type_depense"
                                           value="depense" class="d-none type-radio">
                                    <label for="type_depense"
                                           class="type-option w-100 rounded-4 p-4 text-center"
                                           style="border: 2px solid #e0e0e0; cursor: pointer; transition: all 0.2s;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                                             style="width:70px; height:70px; background: #fde8e8;">
                                            <i class="fas fa-arrow-down fa-2x" style="color: #c0392b;"></i>
                                        </div>
                                        <h5 class="fw-bold mb-1" style="color: #c0392b;">Expense</h5>
                                        <p class="text-muted small mb-0">Money going out of your wallet</p>
                                    </label>
                                </div>
                            </div>

                            <hr class="my-4">

                            <div class="d-flex justify-content-between">
                                <a href="{{ path('app_transaction_new_step1') }}"
                                   class="btn px-4"
                                   style="background: #f5f5f5; color: #26474E; border-radius: 10px;">
                                    <i class="fas fa-arrow-left me-1"></i>Back
                                </a>
                                <button type="submit" class="btn px-4"
                                        style="background: #F27438; color: white; border-radius: 10px;">
                                    Next: Details <i class="fas fa-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .rounded-top-4 { border-radius: 1rem 1rem 0 0 !important; }
    .rounded-4 { border-radius: 1rem !important; }
    .type-radio:checked + .type-option {
        border-color: #F27438 !important;
        background: #fff3ee;
        box-shadow: 0 4px 12px rgba(242,116,56,0.2);
    }
    .type-option:hover { border-color: #F27438 !important; background: #fff8f5; }
</style>
{% endblock %}